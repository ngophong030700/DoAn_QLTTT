@model IReadOnlyList<SqlDemoTableViewModel>

@functions {
    private static string FormatCell(string columnName, object? value)
    {
        if (value == null) return "";

        string valStr = value.ToString() ?? "";

        // Handle TrangThai (Status)
        if (columnName.Equals("TrangThai", StringComparison.OrdinalIgnoreCase) || columnName.Contains("TrangThai", StringComparison.OrdinalIgnoreCase))
        {
            if (valStr.Equals("Trống", StringComparison.OrdinalIgnoreCase) || valStr.Equals("Trong", StringComparison.OrdinalIgnoreCase))
                return "<span class=\"badge bg-success-subtle text-success border border-success-subtle px-2 py-1 rounded-pill\"><i class=\"bi bi-check2-circle me-1\"></i>Trống</span>";
            if (valStr.Equals("Đang thuê", StringComparison.OrdinalIgnoreCase) || valStr.Equals("DangThue", StringComparison.OrdinalIgnoreCase) || valStr.Equals("Đang ở", StringComparison.OrdinalIgnoreCase))
                return "<span class=\"badge bg-primary-subtle text-primary border border-primary-subtle px-2 py-1 rounded-pill\"><i class=\"bi bi-people-fill me-1\"></i>Đang thuê</span>";
            if (valStr.Equals("Đã thanh toán", StringComparison.OrdinalIgnoreCase) || valStr.Equals("DaThanhToan", StringComparison.OrdinalIgnoreCase))
                return "<span class=\"badge bg-success-subtle text-success border border-success-subtle px-2 py-1 rounded-pill\"><i class=\"bi bi-cash-stack me-1\"></i>Đã thanh toán</span>";
            if (valStr.Equals("Chưa thanh toán", StringComparison.OrdinalIgnoreCase) || valStr.Equals("ChuaThanhToan", StringComparison.OrdinalIgnoreCase))
                return "<span class=\"badge bg-danger-subtle text-danger border border-danger-subtle px-2 py-1 rounded-pill\"><i class=\"bi bi-exclamation-triangle-fill me-1\"></i>Chưa thanh toán</span>";
            if (valStr.Equals("Quá hạn", StringComparison.OrdinalIgnoreCase) || valStr.Equals("QuaHan", StringComparison.OrdinalIgnoreCase))
                return "<span class=\"badge bg-danger-subtle text-danger border border-danger-subtle px-2 py-1 rounded-pill\"><i class=\"bi bi-clock-history me-1\"></i>Quá hạn</span>";
            if (valStr.Equals("Còn nợ", StringComparison.OrdinalIgnoreCase) || valStr.Equals("ConNo", StringComparison.OrdinalIgnoreCase))
                return "<span class=\"badge bg-warning-subtle text-warning border border-warning-subtle px-2 py-1 rounded-pill\"><i class=\"bi bi-hourglass-split me-1\"></i>Còn nợ</span>";
            if (valStr.Equals("Hiệu lực", StringComparison.OrdinalIgnoreCase) || valStr.Equals("HieuLuc", StringComparison.OrdinalIgnoreCase) || valStr.Equals("Đang hiệu lực", StringComparison.OrdinalIgnoreCase))
                return "<span class=\"badge bg-success-subtle text-success border border-success-subtle px-2 py-1 rounded-pill\"><i class=\"bi bi-shield-check me-1\"></i>Hiệu lực</span>";
            if (valStr.Equals("Đã kết thúc", StringComparison.OrdinalIgnoreCase) || valStr.Equals("DaKetThuc", StringComparison.OrdinalIgnoreCase) || valStr.Equals("Hết hạn", StringComparison.OrdinalIgnoreCase))
                return "<span class=\"badge bg-secondary-subtle text-secondary border border-secondary-subtle px-2 py-1 rounded-pill\"><i class=\"bi bi-archive-fill me-1\"></i>Đã kết thúc</span>";
        }

        // Handle HinhThuc (payment method)
        if (columnName.Equals("HinhThuc", StringComparison.OrdinalIgnoreCase) || columnName.Equals("HinhThucThanhToan", StringComparison.OrdinalIgnoreCase))
        {
            if (valStr.Equals("TienMat", StringComparison.OrdinalIgnoreCase) || valStr.Equals("Tiền mặt", StringComparison.OrdinalIgnoreCase))
                return "<span class=\"badge bg-success-subtle text-success border border-success-subtle px-2 py-1\"><i class=\"bi bi-cash me-1\"></i>Tiền mặt</span>";
            if (valStr.Equals("ChuyenKhoan", StringComparison.OrdinalIgnoreCase) || valStr.Equals("Chuyển khoản", StringComparison.OrdinalIgnoreCase))
                return "<span class=\"badge bg-info-subtle text-info border border-info-subtle px-2 py-1\"><i class=\"bi bi-bank me-1\"></i>Chuyển khoản</span>";
        }

        // Format money columns (TienThueThang, GiaPhong, TongTien, ConLai, SoTien, ThanhTien, DonGia, GiaThue)
        bool isMoney = columnName.Contains("Gia", StringComparison.OrdinalIgnoreCase) || 
                       columnName.Contains("Tien", StringComparison.OrdinalIgnoreCase) || 
                       columnName.Contains("Coc", StringComparison.OrdinalIgnoreCase) || 
                       columnName.Contains("SoTien", StringComparison.OrdinalIgnoreCase) ||
                       columnName.Contains("ConLai", StringComparison.OrdinalIgnoreCase) ||
                       columnName.Contains("TieuThu", StringComparison.OrdinalIgnoreCase) && valStr.Length > 4; // safety

        if (isMoney && (value is decimal || value is double || value is float || value is int || value is long || decimal.TryParse(valStr, out _)))
        {
            decimal num = 0;
            if (value is decimal d) num = d;
            else if (value is double db) num = (decimal)db;
            else if (value is float f) num = (decimal)f;
            else if (value is int i) num = i;
            else if (value is long l) num = l;
            else decimal.TryParse(valStr, out num);

            return $"<strong class=\"text-dark fw-700\">{num.ToString("N0")} ₫</strong>";
        }

        // Highlight key IDs
        if (columnName.EndsWith("ID", StringComparison.OrdinalIgnoreCase) || columnName.StartsWith("Ma", StringComparison.OrdinalIgnoreCase))
        {
            return $"<code class=\"px-2 py-0.5 bg-light border rounded text-secondary small fw-600\">{valStr}</code>";
        }

        // Handle phone numbers
        if (columnName.Equals("SDT", StringComparison.OrdinalIgnoreCase) || columnName.Equals("DienThoai", StringComparison.OrdinalIgnoreCase) || columnName.Contains("SoDienThoai", StringComparison.OrdinalIgnoreCase))
        {
            return $"<span class=\"text-nowrap\"><i class=\"bi bi-telephone text-muted me-1\"></i>{valStr}</span>";
        }

        //Handle Nam 
        if (columnName.Equals("Nam", StringComparison.OrdinalIgnoreCase))
        {
            return value + "";
        }

        // Handle date columns
        if (value is DateTime dateVal)
        {
            return $"<span class=\"text-nowrap\"><i class=\"bi bi-calendar3 text-muted me-1\"></i>{dateVal.ToString("dd/MM/yyyy")}</span>";
        }
        
        // Format basic types
        return value switch
        {
            bool flag => flag ? "<span class=\"badge bg-success-subtle text-success px-2 py-1\">Có</span>" : "<span class=\"badge bg-light text-muted px-2 py-1\">Không</span>",
            decimal number => number.ToString("N0"),
            double number => number.ToString("N0"),
            float number => number.ToString("N0"),
            int number => number.ToString("N0"),
            long number => number.ToString("N0"),
            _ => valStr
        };
    }
}

@if (Model.Count == 0)
{
    <div class="sql-demo-empty small">
        <i class="bi bi-table fs-5 text-muted"></i>
        <div>Chưa có dữ liệu để hiển thị.</div>
    </div>
}
else
{
    foreach (var table in Model)
    {
        <div class="sql-demo-table-block shadow-sm">
            <div class="sql-demo-table-title d-flex align-items-center gap-2">
                <div class="sql-demo-table-icon-wrap">
                    <i class="bi bi-grid-3x3-gap-fill"></i>
                </div>
                <span>Bảng: <strong class="text-dark">@table.Title</strong></span>
                <span class="badge bg-light text-secondary border ms-auto font-monospace small">@table.Rows.Count dòng</span>
            </div>
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0 sql-demo-table">
                    <thead>
                        <tr>
                            @if (table.Columns.Count == 0)
                            {
                                <th>Kết quả</th>
                            }
                            else
                            {
                                @foreach (var column in table.Columns)
                                {
                                    <th>@column</th>
                                }
                            }
                        </tr>
                    </thead>
                    <tbody>
                        @if (table.Rows.Count == 0)
                        {
                            <tr>
                                <td colspan="@Math.Max(table.Columns.Count, 1)" class="text-muted text-center py-4 fs-7">
                                    <i class="bi bi-inbox me-1"></i>Không có dòng dữ liệu nào được trả về.
                                </td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var row in table.Rows)
                            {
                                <tr>
                                    @foreach (var column in table.Columns)
                                    {
                                        <td>@Html.Raw(FormatCell(column, row.TryGetValue(column, out var value) ? value : null))</td>
                                    }
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
}
