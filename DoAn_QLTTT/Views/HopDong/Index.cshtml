@model IEnumerable<HopDong>
@{
    ViewData["Title"] = "Quản lý hợp đồng";
}

<div class="page-actions">
    <form class="d-flex search-box" method="get">
        <input class="form-control me-2" type="search" name="keyword" value="@ViewBag.Keyword" placeholder="Tìm phòng, khách, trạng thái" />
        <button class="btn btn-outline-secondary" type="submit">Tìm</button>
    </form>
    <a class="btn btn-primary" asp-action="Create">Thêm mới</a>
</div>

<div class="table-card table-responsive">
    <table class="table align-middle">
        <thead>
            <tr>
                <th>Mã</th>
                <th>Phòng</th>
                <th>Khách đại diện</th>
                <th>Ngày bắt đầu</th>
                <th>Ngày kết thúc</th>
                <th class="text-end">Tiền thuê</th>
                <th class="text-end">Tiền cọc</th>
                <th>Trạng thái</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td class="monospace-data">#@item.MaHopDong</td>
                    <td>@item.SoPhong</td>
                    <td>@item.KhachDaiDienHoTen</td>
                    <td class="monospace-data">@item.NgayBatDau.ToString("dd/MM/yyyy")</td>
                    <td class="monospace-data">@(item.NgayKetThuc?.ToString("dd/MM/yyyy") ?? "")</td>
                    <td class="text-end monospace-data">@FormatHelper.Money(item.TienThueThang)</td>
                    <td class="text-end monospace-data">@FormatHelper.Money(item.TienCoc)</td>
                    <td><span class="badge @BadgeHelper.HopDongStatusClass(item.TrangThai)">@item.TrangThai</span></td>
                    <td class="action-cell text-end">
                        <a class="btn btn-sm btn-outline-secondary" asp-action="Details" asp-route-id="@item.MaHopDong">Xem</a>
                        <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@item.MaHopDong">Sửa</a>
                        <a class="btn btn-sm btn-outline-danger" asp-action="Delete" asp-route-id="@item.MaHopDong">Xóa</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
