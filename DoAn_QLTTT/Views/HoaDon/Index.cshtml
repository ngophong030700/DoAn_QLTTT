@model IEnumerable<HoaDon>
@{
    ViewData["Title"] = "Quản lý hóa đơn";
}

<div class="page-actions">
    <form class="d-flex search-box" method="get">
        <input class="form-control me-2" type="search" name="keyword" value="@ViewBag.Keyword" placeholder="Tìm hợp đồng, phòng, khách, trạng thái" />
        <button class="btn btn-outline-secondary" type="submit">Tìm</button>
    </form>
    <div class="d-flex gap-2">
        <form asp-action="LapHoaDonDemo" method="post">
            <button class="btn btn-outline-primary" type="submit">Lập hóa đơn demo</button>
        </form>
        <a class="btn btn-primary" asp-action="Create">Thêm mới</a>
    </div>
</div>

<div class="table-card table-responsive">
    <table class="table align-middle">
        <thead>
            <tr>
                <th>Mã</th>
                <th>Hợp đồng</th>
                <th>Tháng/Năm</th>
                <th class="text-end">Tổng tiền</th>
                <th class="text-end">Đã thanh toán</th>
                <th class="text-end">Còn lại</th>
                <th>Hạn thanh toán</th>
                <th>Trạng thái</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td class="monospace-data">#@item.MaHoaDon</td>
                    <td>@item.HopDongMoTa</td>
                    <td>@item.Thang/@item.Nam</td>
                    <td class="text-end monospace-data">@FormatHelper.Money(item.TongTien)</td>
                    <td class="text-end monospace-data">@FormatHelper.Money(item.DaThanhToan)</td>
                    <td class="text-end fw-semibold monospace-data">@FormatHelper.Money(item.ConLai)</td>
                    <td>@item.HanThanhToan.ToString("dd/MM/yyyy")</td>
                    <td><span class="badge @BadgeHelper.HoaDonStatusClass(item.TrangThai)">@item.TrangThai</span></td>
                    <td class="action-cell text-end">
                        <a class="btn btn-sm btn-outline-secondary" asp-action="Details" asp-route-id="@item.MaHoaDon">Xem</a>
                        <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@item.MaHoaDon">Sửa</a>
                        <a class="btn btn-sm btn-outline-danger" asp-action="Delete" asp-route-id="@item.MaHoaDon">Xóa</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
