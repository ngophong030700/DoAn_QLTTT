@model ThanhToan
@{
    ViewData["Title"] = "Chi tiết thanh toán";
}

<div class="detail-panel">
    <dl class="row mb-0">
        <dt class="col-sm-3">Mã thanh toán</dt>
        <dd class="col-sm-9">#@Model.MaThanhToan</dd>
        <dt class="col-sm-3">Hóa đơn</dt>
        <dd class="col-sm-9">@Model.HoaDonMoTa</dd>
        <dt class="col-sm-3">Người thu</dt>
        <dd class="col-sm-9">@Model.NguoiThuHoTen</dd>
        <dt class="col-sm-3">Số tiền</dt>
        <dd class="col-sm-9">@FormatHelper.Money(Model.SoTien)</dd>
        <dt class="col-sm-3">Ngày thu</dt>
        <dd class="col-sm-9">@Model.NgayThu.ToString("dd/MM/yyyy")</dd>
        <dt class="col-sm-3">Hình thức</dt>
        <dd class="col-sm-9">
            <span class="badge rounded-pill px-3 py-2 @BadgeHelper.HinhThucThanhToanClass(Model.HinhThuc)">
                @BadgeHelper.HinhThucThanhToanText(Model.HinhThuc)
            </span>
        </dd>
    </dl>
    <div class="mt-4 d-flex gap-2">
        <a class="btn btn-primary" asp-action="Edit" asp-route-id="@Model.MaThanhToan">Sửa</a>
        <a class="btn btn-outline-secondary" asp-action="Index">Quay lại</a>
    </div>
</div>
