@model IEnumerable<ThanhToan>
@{
    ViewData["Title"] = "Ghi nhận thanh toán";
}

<div class="page-actions">
    <form class="d-flex search-box" method="get">
        <input class="form-control me-2" type="search" name="keyword" value="@ViewBag.Keyword" placeholder="Tìm hóa đơn, người thu, hình thức" />
        <button class="btn btn-outline-secondary" type="submit">Tìm</button>
    </form>
    <a class="btn btn-primary" asp-action="Create">Thêm mới</a>
</div>

<div class="table-card table-responsive">
    <table class="table align-middle">
        <thead>
            <tr>
                <th>Mã</th>
                <th>Hóa đơn</th>
                <th>Người thu</th>
                <th>Số tiền</th>
                <th>Ngày thu</th>
                <th>Hình thức</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>#@item.MaThanhToan</td>
                    <td>@item.HoaDonMoTa</td>
                    <td>@item.NguoiThuHoTen</td>
                    <td class="fw-semibold">@FormatHelper.Money(item.SoTien)</td>
                    <td>@item.NgayThu.ToString("dd/MM/yyyy")</td>
                    <td>@item.HinhThuc</td>
                    <td class="action-cell text-end">
                        <a class="btn btn-sm btn-outline-secondary" asp-action="Details" asp-route-id="@item.MaThanhToan">Xem</a>
                        <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@item.MaThanhToan">Sửa</a>
                        <a class="btn btn-sm btn-outline-danger" asp-action="Delete" asp-route-id="@item.MaThanhToan">Xóa</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
