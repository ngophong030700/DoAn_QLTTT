@model IEnumerable<ChiSoDienNuoc>
@{
    ViewData["Title"] = "Ghi chỉ số điện/nước";
}

<div class="page-actions">
    <form class="d-flex search-box" method="get">
        <input class="form-control me-2" type="search" name="keyword" value="@ViewBag.Keyword" placeholder="Tìm phòng, dịch vụ, tháng/năm" />
        <button class="btn btn-outline-secondary" type="submit">Tìm</button>
    </form>
    <a class="btn btn-primary" asp-action="Create">Ghi chỉ số</a>
</div>

<div class="table-card table-responsive">
    <table class="table align-middle">
        <thead>
            <tr>
                <th>Phòng</th>
                <th>Dịch vụ</th>
                <th>Tháng/Năm</th>
                <th class="text-end">Chỉ số cũ</th>
                <th class="text-end">Chỉ số mới</th>
                <th class="text-end">Tiêu thụ</th>
                <th>Người nhập</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td class="fw-semibold">@item.SoPhong</td>
                    <td>@item.DichVuTen</td>
                    <td>@item.Thang/@item.Nam</td>
                    <td class="text-end monospace-data">@FormatHelper.Number(item.ChiSoCu)</td>
                    <td class="text-end monospace-data">@FormatHelper.Number(item.ChiSoMoi)</td>
                    <td class="text-end fw-semibold monospace-data">@FormatHelper.Number(item.TieuThu)</td>
                    <td>@item.NguoiNhapHoTen</td>
                    <td class="action-cell text-end">
                        <a class="btn btn-sm btn-outline-secondary" asp-action="Details" asp-route-id="@item.MaChiSo">Xem</a>
                        <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@item.MaChiSo">Sửa</a>
                        @if (User.IsInRole(AppStatuses.VaiTro.Admin))
                        {
                            <a class="btn btn-sm btn-outline-danger" asp-action="Delete" asp-route-id="@item.MaChiSo">Xóa</a>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
