@model IEnumerable<PhongTro>
@{
    ViewData["Title"] = "Quản lý thuê phòng trọ";
}

<div class="page-actions">
    <form class="d-flex search-box" method="get">
        <input class="form-control me-2" type="search" name="keyword" value="@ViewBag.Keyword" placeholder="Tìm phòng, loại, trạng thái" />
        <button class="btn btn-outline-secondary" type="submit">Tìm</button>
    </form>
    @if (User.IsInRole(AppStatuses.VaiTro.Admin))
    {
        <a class="btn btn-primary" asp-action="Create">Thêm mới</a>
    }
</div>

<div class="table-card table-responsive">
    <table class="table align-middle">
        <thead>
            <tr>
                <th>Số phòng</th>
                <th>Loại phòng</th>
                <th class="text-end">Giá thuê</th>
                <th class="text-center">Sức chứa</th>
                <th class="text-center">Trạng thái</th>
                <th>Ghi chú</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td class="fw-semibold monospace-data">@item.SoPhong</td>
                    <td>@item.LoaiPhongTen</td>
                    <td class="text-end monospace-data">@FormatHelper.Money(item.GiaThue)</td>
                    <td class="text-center">@item.SucChuaToiDa</td>
                    <td class="text-center">
                        <span class="badge rounded-pill px-3 py-2 @BadgeHelper.PhongStatusClass(item.TrangThai)">
                            @BadgeHelper.PhongStatusText(item.TrangThai)
                        </span>
                    </td>
                    <td class="text-secondary">@(string.IsNullOrWhiteSpace(item.GhiChu) ? "—" : item.GhiChu)</td>
                    <td class="action-cell text-end">
                        <a class="btn btn-sm btn-outline-secondary" asp-action="Details" asp-route-id="@item.MaPhong">Xem</a>
                        <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@item.MaPhong">Sửa</a>
                        @if (User.IsInRole(AppStatuses.VaiTro.Admin))
                        {
                            <a class="btn btn-sm btn-outline-danger" asp-action="Delete" asp-route-id="@item.MaPhong">Xóa</a>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
