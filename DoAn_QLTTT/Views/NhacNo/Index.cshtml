@model NhacNoViewModel
@{
    ViewData["Title"] = "Nhắc nợ";
}

<div class="page-actions">
    <form class="d-flex search-box" method="get">
        <input class="form-control me-2" type="search" name="keyword" value="@ViewBag.Keyword" placeholder="Tìm số phòng, họ tên, mã..." />
        <button class="btn btn-outline-secondary" type="submit">Tìm</button>
    </form>
</div>

<div class="table-card table-responsive">
    <table class="table align-middle">
        <thead>
            <tr>
                <th>Mã</th>
                <th>Hợp đồng</th>
                <th>Khách</th>
                <th>Tháng/Năm</th>
                <th>Hạn thanh toán</th>
                <th class="text-end">Còn lại</th>
                <th>Trạng thái</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.HoaDonQuaHans)
            {
                <tr>
                    <td class="monospace-data">#@item.MaHoaDon</td>
                    <td>
                        <span class="badge bg-primary bg-opacity-10 text-primary border border-primary">HĐ #@item.MaHopDong</span>
                        <div class="small text-secondary mt-1"><i class="bi bi-door-open me-1"></i>Phòng @(item.SoPhong ?? "—")</div>
                    </td>
                    <td>
                        <div class="fw-semibold text-dark">@(item.KhachDaiDienHoTen ?? "Chưa có thông tin")</div>
                    </td>
                    <td>@item.Thang/@item.Nam</td>
                    <td class="monospace-data">@item.HanThanhToan.ToString("dd/MM/yyyy")</td>
                    <td class="text-end fw-semibold monospace-data">@FormatHelper.Money(item.ConLai)</td>
                    <td>
                        <span class="badge rounded-pill px-3 py-2 @BadgeHelper.HoaDonStatusClass(item.TrangThai)">
                            @BadgeHelper.HoaDonStatusText(item.TrangThai)
                        </span>
                    </td>
                    <td class="text-end">
                        <a class="btn btn-sm btn-outline-secondary" asp-controller="HoaDon" asp-action="Details" asp-route-id="@item.MaHoaDon">Xem hóa đơn</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
