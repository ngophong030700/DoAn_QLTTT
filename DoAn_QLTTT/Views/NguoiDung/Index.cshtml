@model IEnumerable<NguoiDung>
@{
    ViewData["Title"] = "Quản lý người dùng";
}

<div class="page-actions">
    <form class="d-flex search-box" method="get">
        <input class="form-control me-2" type="search" name="keyword" value="@ViewBag.Keyword" placeholder="Tìm tài khoản, họ tên, vai trò" />
        <button class="btn btn-outline-secondary" type="submit">Tìm</button>
    </form>
    <a class="btn btn-primary" asp-action="Create">Thêm mới</a>
</div>

<div class="table-card table-responsive">
    <table class="table align-middle">
        <thead>
            <tr>
                <th>Tên đăng nhập</th>
                <th>Họ tên</th>
                <th>Vai trò</th>
                <th>Hoạt động</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td class="fw-semibold">@item.TenDangNhap</td>
                    <td>@item.HoTen</td>
                    <td><span class="badge @BadgeHelper.VaiTroClass(item.VaiTro)">@item.VaiTro</span></td>
                    <td>
                        @if (item.DangHoatDong)
                        {
                            <span class="badge text-bg-success">Có</span>
                        }
                        else
                        {
                            <span class="badge text-bg-secondary">Không</span>
                        }
                    </td>
                    <td class="action-cell text-end">
                        <a class="btn btn-sm btn-outline-secondary" asp-action="Details" asp-route-id="@item.MaNguoiDung">Xem</a>
                        <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@item.MaNguoiDung">Sửa</a>
                        <a class="btn btn-sm btn-outline-danger" asp-action="Delete" asp-route-id="@item.MaNguoiDung">Xóa</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
