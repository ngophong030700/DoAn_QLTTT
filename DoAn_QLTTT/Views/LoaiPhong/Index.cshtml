@model IEnumerable<LoaiPhong>
@{
    ViewData["Title"] = "Quản lý loại phòng";
}

<div class="page-actions">
    <form class="d-flex search-box" method="get">
        <input class="form-control me-2" type="search" name="keyword" value="@ViewBag.Keyword" placeholder="Tìm theo tên loại" />
        <button class="btn btn-outline-secondary" type="submit">Tìm</button>
    </form>
    <a class="btn btn-primary" asp-action="Create">Thêm mới</a>
</div>

<div class="table-card table-responsive">
    <table class="table align-middle">
        <thead>
            <tr>
                <th>Mã</th>
                <th>Tên loại</th>
                <th class="text-end">Diện tích</th>
                <th class="text-end">Giá thuê cơ sở</th>
                <th class="text-center">Sức chứa</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td class="monospace-data">#@item.MaLoaiPhong</td>
                    <td>@item.TenLoai</td>
                    <td class="text-end monospace-data">@FormatHelper.Number(item.DienTich) m²</td>
                    <td class="text-end monospace-data">@FormatHelper.Money(item.GiaThueCoSo)</td>
                    <td class="text-center">@item.SucChuaToiDa</td>
                    <td class="action-cell text-end">
                        <a class="btn btn-sm btn-outline-secondary" asp-action="Details" asp-route-id="@item.MaLoaiPhong">Xem</a>
                        <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@item.MaLoaiPhong">Sửa</a>
                        <a class="btn btn-sm btn-outline-danger" asp-action="Delete" asp-route-id="@item.MaLoaiPhong">Xóa</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
