@model IEnumerable<DichVu>
@{
    ViewData["Title"] = "Quản lý dịch vụ";
}

<div class="page-actions">
    <form class="d-flex search-box" method="get">
        <input class="form-control me-2" type="search" name="keyword" value="@ViewBag.Keyword" placeholder="Tìm dịch vụ, đơn vị, loại phí" />
        <button class="btn btn-outline-secondary" type="submit">Tìm</button>
    </form>
    <a class="btn btn-primary" asp-action="Create">Thêm mới</a>
</div>

<div class="table-card table-responsive">
    <table class="table align-middle">
        <thead>
            <tr>
                <th>Tên dịch vụ</th>
                <th>Đơn vị</th>
                <th>Đơn giá</th>
                <th>Loại tính phí</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td class="fw-semibold">@item.TenDichVu</td>
                    <td>@item.DonVi</td>
                    <td>@FormatHelper.Money(item.DonGia)</td>
                    <td><span class="badge text-bg-light text-dark">@item.LoaiTinhPhi</span></td>
                    <td class="action-cell text-end">
                        <a class="btn btn-sm btn-outline-secondary" asp-action="Details" asp-route-id="@item.MaDichVu">Xem</a>
                        <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@item.MaDichVu">Sửa</a>
                        <a class="btn btn-sm btn-outline-danger" asp-action="Delete" asp-route-id="@item.MaDichVu">Xóa</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
