@model DashboardViewModel
@{
    ViewData["Title"] = "Tổng quan nhà trọ";
    var isStaff = User.IsInRole(AppStatuses.VaiTro.Staff);
}

<!-- Prominent Pending Task Warnings -->
@if (Model.HoaDonQuaHan > 0 || Model.TongCongNo > 0)
{
    <div class="alert alert-danger border-0 shadow-sm rounded-4 d-flex align-items-start gap-3 p-3.5 mb-4" role="alert" style="background-color: rgba(239, 68, 68, 0.06); border: 1px solid rgba(239, 68, 68, 0.15) !important;">
        <div class="bg-danger bg-opacity-15 text-danger rounded-circle d-flex align-items-center justify-content-center" style="width: 44px; height: 44px; flex-shrink: 0;">
            <i class="bi bi-exclamation-triangle-fill fs-4"></i>
        </div>
        <div class="flex-grow-1">
            <h4 class="alert-heading h6 fw-800 text-danger mb-1">Cảnh báo công nợ cần xử lý</h4>
            <div class="text-secondary small leading-relaxed">
                @if (Model.HoaDonQuaHan > 0)
                {
                    <span class="d-block mb-1"><i class="bi bi-calendar-x text-danger me-1"></i> Có <strong>@Model.HoaDonQuaHan</strong> hóa đơn đã quá hạn thanh toán chưa được giải quyết.</span>
                }
                @if (Model.TongCongNo > 0)
                {
                    <span class="d-block"><i class="bi bi-cash-stack text-danger me-1"></i> Tổng số tiền khách hàng còn nợ là <strong>@FormatHelper.Money(Model.TongCongNo)</strong>.</span>
                }
            </div>
            <div class="mt-2.5 d-flex gap-2">
                <a asp-controller="NhacNo" asp-action="Index" class="btn btn-sm btn-danger fw-700 rounded-2">
                    <i class="bi bi-send-fill me-1"></i> Gửi thông báo nhắc nợ
                </a>
                <a asp-controller="HoaDon" asp-action="Index" class="btn btn-sm btn-outline-danger fw-700 rounded-2">
                    <i class="bi bi-receipt-cutoff me-1"></i> Xem danh sách hóa đơn
                </a>
            </div>
        </div>
    </div>
}

<!-- 8 KPI Cards Grid -->
<div class="row g-4 mb-4">
    <!-- Row 1: Rooms KPIs -->
    <div class="col-sm-6 col-xl-3">
        <div class="stat-card primary">
            <div class="d-flex justify-content-between align-items-start">
                <div class="flex-grow-1">
                    <div class="stat-label">Tổng số phòng</div>
                    <div class="stat-value text-primary mt-1">@Model.TongSoPhong</div>
                    <div class="mt-2 text-secondary fs-8 fw-600">
                        <i class="bi bi-house-door me-1 text-primary"></i>Khu trọ đang quản lý
                    </div>
                </div>
                <div class="stat-icon-wrap bg-primary bg-opacity-10 text-primary">
                    <i class="bi bi-house-fill"></i>
                </div>
            </div>
        </div>
    </div>
    
    <div class="col-sm-6 col-xl-3">
        <div class="stat-card success">
            <div class="d-flex justify-content-between align-items-start">
                <div class="flex-grow-1">
                    <div class="stat-label">Phòng trống</div>
                    <div class="stat-value text-success mt-1">@Model.PhongTrong</div>
                    <div class="mt-2 text-secondary fs-8 fw-600">
                        <i class="bi bi-check2-circle me-1 text-success"></i>Có thể lập hợp đồng ngay
                    </div>
                </div>
                <div class="stat-icon-wrap bg-success bg-opacity-10 text-success">
                    <i class="bi bi-door-open-fill"></i>
                </div>
            </div>
        </div>
    </div>

    <div class="col-sm-6 col-xl-3">
        <div class="stat-card info">
            <div class="d-flex justify-content-between align-items-start">
                <div class="flex-grow-1">
                    <div class="stat-label">Phòng đang thuê</div>
                    <div class="stat-value text-info mt-1">@Model.PhongDangThue</div>
                    <div class="mt-2 text-secondary fs-8 fw-600">
                        <i class="bi bi-people me-1 text-info"></i>Đang ở ổn định
                    </div>
                </div>
                <div class="stat-icon-wrap bg-info bg-opacity-10 text-info">
                    <i class="bi bi-people-fill"></i>
                </div>
            </div>
        </div>
    </div>

    <div class="col-sm-6 col-xl-3">
        <div class="stat-card warning">
            <div class="d-flex justify-content-between align-items-start">
                <div class="flex-grow-1">
                    <div class="stat-label">Phòng bảo trì</div>
                    <div class="stat-value text-warning mt-1">@Model.PhongBaoTri</div>
                    <div class="mt-2 text-secondary fs-8 fw-600">
                        <i class="bi bi-tools me-1 text-warning"></i>Đang sửa chữa nâng cấp
                    </div>
                </div>
                <div class="stat-icon-wrap bg-warning bg-opacity-10 text-warning">
                    <i class="bi bi-wrench-adjustable-circle-fill"></i>
                </div>
            </div>
        </div>
    </div>

    <!-- Row 2: Financial KPIs -->
    @if (!isStaff)
    {
        <div class="col-sm-6 col-xl-3">
            <div class="stat-card success">
                <div class="d-flex justify-content-between align-items-start">
                    <div class="flex-grow-1">
                        <div class="stat-label">Doanh thu tháng này</div>
                        <div class="stat-value text-success mt-1">@FormatHelper.Money(Model.DoanhThuThang)</div>
                        <div class="mt-2 text-secondary fs-8 fw-600">
                            <i class="bi bi-cash-stack me-1 text-success"></i>Đã ghi nhận trong kỳ
                        </div>
                    </div>
                    <div class="stat-icon-wrap bg-success bg-opacity-10 text-success">
                        <i class="bi bi-cash-coin"></i>
                    </div>
                </div>
            </div>
        </div>
    }

    <div class="col-sm-6 col-xl-3">
        <div class="stat-card warning">
            <div class="d-flex justify-content-between align-items-start">
                <div class="flex-grow-1">
                    <div class="stat-label">Tổng công nợ chưa thu</div>
                    <div class="stat-value text-warning mt-1">@FormatHelper.Money(Model.TongCongNo)</div>
                    <div class="mt-2 text-secondary fs-8 fw-600">
                        <i class="bi bi-exclamation-triangle me-1 text-warning"></i>Tiền phòng & dịch vụ nợ dồn
                    </div>
                </div>
                <div class="stat-icon-wrap bg-warning bg-opacity-10 text-warning">
                    <i class="bi bi-wallet2"></i>
                </div>
            </div>
        </div>
    </div>

    <div class="col-sm-6 col-xl-3">
        <div class="stat-card danger">
            <div class="d-flex justify-content-between align-items-start">
                <div class="flex-grow-1">
                    <div class="stat-label">Hóa đơn nợ chưa trả</div>
                    <div class="stat-value text-danger mt-1">@Model.HoaDonChuaThanhToan</div>
                    <div class="mt-2 text-secondary fs-8 fw-600">
                        <i class="bi bi-receipt me-1 text-danger"></i>Hóa đơn còn nợ một phần/toàn bộ
                    </div>
                </div>
                <div class="stat-icon-wrap bg-danger bg-opacity-10 text-danger">
                    <i class="bi bi-file-earmark-diff-fill"></i>
                </div>
            </div>
        </div>
    </div>

    <div class="col-sm-6 col-xl-3">
        <div class="stat-card danger animate-pulse">
            <div class="d-flex justify-content-between align-items-start">
                <div class="flex-grow-1">
                    <div class="stat-label">Hóa đơn quá hạn</div>
                    <div class="stat-value text-danger mt-1">@Model.HoaDonQuaHan</div>
                    <div class="mt-2 text-secondary fs-8 fw-600">
                        <i class="bi bi-calendar-x me-1 text-danger"></i>Hóa đơn đã trễ hạn thanh toán
                    </div>
                </div>
                <div class="stat-icon-wrap bg-danger bg-opacity-10 text-danger" style="animation: pulse 2s infinite;">
                    <i class="bi bi-exclamation-octagon-fill"></i>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row g-4 mb-4">
    <!-- Chart 1: Revenue Trends -->
    @if (!isStaff)
    {
        <div class="col-xl-8">
            <div class="table-card p-4 border bg-white shadow-sm rounded-4">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <div>
                        <h2 class="h5 fw-800 text-dark mb-1"><i class="bi bi-bar-chart-line-fill me-2 text-primary"></i>Xu hướng doanh thu</h2>
                        <p class="text-muted small mb-0 fw-600">Theo dõi doanh thu phòng trọ trong 6 tháng gần nhất</p>
                    </div>
                    <span class="badge bg-light text-secondary border fw-700 py-1.5 px-2.5">Đơn vị: VNĐ</span>
                </div>
                <div style="position: relative; height: 320px; width: 100%;">
                    <canvas id="revenueChart"></canvas>
                </div>
            </div>
        </div>
    }

    <!-- Chart 2: Occupancy Rate Doughnut -->
    <div class="@(isStaff ? "col-xl-12" : "col-xl-4")">
        <div class="table-card p-4 border bg-white shadow-sm rounded-4">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <div>
                    <h2 class="h5 fw-800 text-dark mb-1"><i class="bi bi-pie-chart-fill me-2 text-warning"></i>Trạng thái phòng</h2>
                    <p class="text-muted small mb-0 fw-600">Tỷ lệ lấp đầy thực tế</p>
                </div>
                <span class="badge bg-primary bg-opacity-10 text-primary border border-primary border-opacity-10 fw-700 py-1.5 px-2.5">
                    Lấp đầy: @(Model.TongSoPhong > 0 ? (Model.PhongDangThue * 100 / Model.TongSoPhong) : 0)%
                </span>
            </div>
            <div style="position: relative; height: 320px; width: 100%;">
                <canvas id="occupancyChart"></canvas>
            </div>
        </div>
    </div>
</div>

<div class="row g-4 mb-4">
    <!-- Chart 3: Debt Ratio -->
    <div class="col-xl-6">
        <div class="table-card p-4 border bg-white shadow-sm rounded-4">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <div>
                    <h2 class="h5 fw-800 text-dark mb-1">
                        <i class="bi bi-shield-exclamation text-danger me-2"></i>Tỷ lệ nợ động / quá hạn
                    </h2>
                    <p class="text-muted small mb-0 fw-600">Cho thấy tỷ lệ công nợ và nợ quá hạn trong hệ thống</p>
                </div>
                <span class="badge bg-light text-secondary border fw-700 py-1.5 px-2.5">Đơn vị: %</span>
            </div>
            <div style="position: relative; height: 320px; width: 100%;">
                <canvas id="debtRatioChart"></canvas>
            </div>
        </div>
    </div>

    <!-- Chart 4: Top Rooms Utilities -->
    <div class="col-xl-6">
        <div class="table-card p-4 border bg-white shadow-sm rounded-4">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <div>
                    <h2 class="h5 fw-800 text-dark mb-1">
                        <i class="bi bi-lightning-charge-fill text-warning me-2"></i>Danh sách phòng dùng nhiều điện nước
                    </h2>
                    <p class="text-muted small mb-0 fw-600">Xác định các phòng tiêu thụ điện/nước cao nhất</p>
                </div>
                <div style="width: 130px;">
                    <select id="filterUtilityType" class="form-select form-select-sm fw-700 rounded-3 text-secondary border">
                        <option value="All">Tất cả</option>
                        <option value="Điện">Điện</option>
                        <option value="Nước">Nước</option>
                    </select>
                </div>
            </div>
            <div style="position: relative; height: 320px; width: 100%;">
                <canvas id="topUtilityRoomChart"></canvas>
            </div>
        </div>
    </div>
</div>

<div class="row g-4 mb-4">
    <!-- Chart 5: Expiring Contracts -->
    <div class="col-xl-12">
        <div class="table-card p-4 border bg-white shadow-sm rounded-4">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <div>
                    <h2 class="h5 fw-800 text-dark mb-1">
                        <i class="bi bi-calendar-event-fill text-primary me-2"></i>Hợp đồng sắp hết hạn
                    </h2>
                    <p class="text-muted small mb-0 fw-600">Theo dõi các hợp đồng sắp hết hạn để chủ trọ xử lý gia hạn hoặc nhắc khách</p>
                </div>
                <span class="badge bg-light text-secondary border fw-700 py-1.5 px-2.5">Thời hạn: ≤ 60 ngày</span>
            </div>
            <div class="row">
                <div class="col-lg-6 mb-4 mb-lg-0">
                    <div style="position: relative; height: 320px; width: 100%;">
                        <canvas id="expiringContractChart"></canvas>
                    </div>
                </div>
                <div class="col-lg-6">
                    <div class="table-responsive border rounded-3" style="max-height: 320px; overflow-y: auto;">
                        <table class="table table-hover align-middle mb-0" id="expiringContractsTable">
                            <thead class="bg-light sticky-top">
                                <tr>
                                    <th>Số phòng</th>
                                    <th>Khách đại diện</th>
                                    <th>Số điện thoại</th>
                                    <th>Ngày kết thúc</th>
                                    <th class="text-end">Còn lại</th>
                                    <th class="text-center">Cảnh báo</th>
                                </tr>
                            </thead>
                            <tbody>
                                <!-- Dinamically rendered by Javascript -->
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row g-4">
    <!-- Recent Bills Table -->
    <div class="col-xl-8">
        <div class="table-card shadow-sm border bg-white rounded-4">
            <div class="p-3 border-bottom d-flex justify-content-between align-items-center bg-light">
                <h2 class="h6 mb-0 fw-800 text-uppercase tracking-wider text-dark d-flex align-items-center gap-2">
                    <i class="bi bi-clock-history text-primary"></i>Hóa đơn gần đây
                </h2>
                <a class="btn btn-xs btn-outline-primary fw-700 rounded-3 px-3" asp-controller="HoaDon" asp-action="Index">
                    Xem tất cả <i class="bi bi-arrow-right ms-1"></i>
                </a>
            </div>
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead>
                        <tr>
                            <th style="width: 90px;">Mã HĐ</th>
                            <th>Mô tả / Phòng</th>
                            <th>Thời gian</th>
                            <th class="text-end">Tổng tiền</th>
                            <th class="text-end">Đã thu</th>
                            <th class="text-end">Còn lại</th>
                            <th>Hạn TT</th>
                            <th class="text-center" style="width: 140px;">Trạng thái</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.HoaDonGanDay.Count == 0)
                        {
                            <tr>
                                <td colspan="8" class="text-center py-4 text-muted">
                                    <i class="bi bi-inbox me-1"></i>Không có hóa đơn nào gần đây.
                                </td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var item in Model.HoaDonGanDay)
                            {
                                <tr>
                                    <td><code class="px-2 py-0.5 bg-light border rounded text-secondary font-monospace small">#@item.MaHoaDon</code></td>
                                    <td class="fw-700 text-dark">@item.HopDongMoTa</td>
                                    <td class="text-secondary small fw-600">Tháng @item.Thang/@item.Nam</td>
                                    <td class="text-end fw-700 text-dark">@FormatHelper.Money(item.TongTien)</td>
                                    <td class="text-end text-success fw-600">@FormatHelper.Money(item.DaThanhToan)</td>
                                    <td class="text-end text-danger fw-700">@FormatHelper.Money(item.ConLai)</td>
                                    <td class="text-secondary small"><i class="bi bi-calendar3 text-muted me-1"></i>@item.HanThanhToan.ToString("dd/MM/yyyy")</td>
                                    <td class="text-center">
                                        <span class="badge px-2.5 py-1 rounded-pill @BadgeHelper.HoaDonStatusClass(item.TrangThai)">
                                            @BadgeHelper.HoaDonStatusText(item.TrangThai)
                                        </span>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Active Rooms List -->
    <div class="col-xl-4">
        <div class="table-card shadow-sm border bg-white rounded-4">
            <div class="p-3 border-bottom d-flex justify-content-between align-items-center bg-light">
                <h2 class="h6 mb-0 fw-800 text-uppercase tracking-wider text-dark d-flex align-items-center gap-2">
                    <i class="bi bi-house-door-fill text-success"></i>Phòng đang thuê
                </h2>
                <a class="btn btn-xs btn-outline-success fw-700 rounded-3 px-3" asp-controller="PhongTro" asp-action="Index">
                    Xem tất cả
                </a>
            </div>
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead>
                        <tr>
                            <th>Tên Phòng</th>
                            <th class="text-end">Giá thuê / Tháng</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.PhongDangThueList.Count == 0)
                        {
                            <tr>
                                <td colspan="2" class="text-center py-4 text-muted">
                                    <i class="bi bi-door-open me-1"></i>Chưa có phòng nào đang thuê.
                                </td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var item in Model.PhongDangThueList)
                            {
                                <tr>
                                    <td class="fw-700 text-dark">
                                        <div class="d-flex align-items-center gap-2">
                                            <span class="d-inline-block rounded-circle bg-success shadow-sm" style="width: 8px; height: 8px;"></span>
                                            @item.SoPhong
                                        </div>
                                    </td>
                                    <td class="text-end fw-800 text-primary">@FormatHelper.Money(item.GiaThue)</td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            // Helper for gradients
            function getGradient(ctx, color1, color2) {
                const gradient = ctx.createLinearGradient(0, 0, 0, 320);
                gradient.addColorStop(0, color1);
                gradient.addColorStop(1, color2);
                return gradient;
            }

            // Setup Revenue Chart
            const revenueCanvas = document.getElementById('revenueChart');
            if (revenueCanvas) {
                const ctxRevenue = revenueCanvas.getContext('2d');
                const blueGradient = getGradient(ctxRevenue, 'rgba(59, 130, 246, 0.85)', 'rgba(59, 130, 246, 0.15)');

                new Chart(ctxRevenue, {
                type: 'bar',
                data: {
                    labels: @Html.Raw(Json.Serialize(Model.MonthlyRevenueLabels)),
                    datasets: [{
                        label: 'Doanh thu',
                        data: @Html.Raw(Json.Serialize(Model.MonthlyRevenueValues)),
                        backgroundColor: blueGradient,
                        borderColor: 'var(--primary)',
                        borderWidth: 2,
                        borderRadius: 6,
                        hoverBackgroundColor: 'var(--primary)',
                        hoverBorderColor: 'var(--primary)',
                        barPercentage: 0.5
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    interaction: {
                        intersect: false,
                        mode: 'index'
                    },
                    plugins: {
                        legend: { display: false },
                        tooltip: {
                            backgroundColor: 'rgba(255, 255, 255, 0.98)',
                            titleColor: '#0f172a',
                            titleFont: { size: 12, weight: 'bold' },
                            bodyColor: '#475569',
                            bodyFont: { size: 12, weight: '600' },
                            borderColor: 'rgba(59, 130, 246, 0.2)',
                            borderWidth: 1,
                            padding: 12,
                            displayColors: false,
                            shadowColor: 'rgba(0, 0, 0, 0.08)',
                            shadowBlur: 10,
                            callbacks: {
                                label: function(context) {
                                    return ' Doanh thu: ' + new Intl.NumberFormat('vi-VN', { style: 'currency', currency: 'VND' }).format(context.parsed.y);
                                }
                            }
                        }
                    },
                    scales: {
                        y: {
                            beginAtZero: true,
                            border: { display: false },
                            grid: {
                                color: 'rgba(15, 23, 42, 0.04)',
                                drawBorder: false
                            },
                            ticks: {
                                font: { size: 10, weight: '700' },
                                color: '#94a3b8',
                                callback: function(value) {
                                    return new Intl.NumberFormat('vi-VN', { notation: "compact", compactDisplay: "short" }).format(value);
                                }
                            }
                        },
                        x: {
                            border: { display: false },
                            grid: { display: false },
                            ticks: {
                                font: { size: 10, weight: '700' },
                                color: '#94a3b8'
                            }
                        }
                    }
                }
                });
            }

            // Center Text Plugin for Doughnut Chart
            const centerTextPlugin = {
                id: 'centerText',
                beforeDraw: function (chart) {
                    if (chart.config.type === 'doughnut') {
                        const { width, height, ctx } = chart;
                        ctx.restore();
                        const fontSize = (height / 140).toFixed(2);
                        ctx.font = `bold ${fontSize}em "Plus Jakarta Sans", sans-serif`;
                        ctx.textBaseline = "middle";

                        const text = "@(Model.TongSoPhong > 0 ? (Model.PhongDangThue * 100 / Model.TongSoPhong) : 0)%";
                        const textX = Math.round((width - ctx.measureText(text).width) / 2);
                        const textY = Math.round((height - chart.legend.height) / 2);

                        ctx.fillStyle = "#0f172a";
                        ctx.fillText(text, textX, textY);
                        ctx.save();
                    }
                }
            };

            // Setup Room Occupancy Chart
            const ctxOccupancy = document.getElementById('occupancyChart').getContext('2d');
            new Chart(ctxOccupancy, {
                type: 'doughnut',
                data: {
                    labels: ['Trống', 'Đang thuê', 'Bảo trì'],
                    datasets: [{
                        data: [@Model.PhongTrong, @Model.PhongDangThue, @Model.PhongBaoTri],
                        backgroundColor: [
                            'rgba(16, 185, 129, 0.85)',
                            'rgba(59, 130, 246, 0.85)',
                            'rgba(245, 158, 11, 0.85)'
                        ],
                        hoverBackgroundColor: [
                            '#10b981',
                            '#3b82f6',
                            '#f59e0b'
                        ],
                        borderColor: '#ffffff',
                        borderWidth: 4,
                        offset: 2
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    cutout: '76%',
                    plugins: {
                        legend: {
                            position: 'bottom',
                            labels: {
                                usePointStyle: true,
                                pointStyle: 'circle',
                                padding: 16,
                                font: { size: 11, weight: '700' },
                                color: '#475569'
                            }
                        },
                        tooltip: {
                            backgroundColor: 'rgba(255, 255, 255, 0.98)',
                            titleColor: '#0f172a',
                            bodyColor: '#475569',
                            borderColor: 'rgba(15, 23, 42, 0.05)',
                            borderWidth: 1,
                            padding: 12,
                            bodyFont: { size: 12, weight: '700' }
                        }
                    }
                },
                plugins: [centerTextPlugin]
            });

            // Declare chart variables
            let debtRatioChart;
            let topUtilityRoomChart;
            let expiringContractChart;

            // Fetch extra charts data from API
            fetch('/Dashboard/GetExtraChartsData')
                .then(response => response.json())
                .then(data => {
                    const debtRatio = data.debtRatio || data.DebtRatio || {};
                    const topUtilities = data.topUtilities || data.TopUtilities || [];
                    const expiringContracts = data.expiringContracts || data.ExpiringContracts || [];

                    // 1. Debt Ratio Chart (Dashboard 3)
                    const tyLeNoDong = debtRatio.tyLeNoDong_PhanTram !== undefined ? debtRatio.tyLeNoDong_PhanTram : (debtRatio.TyLeNoDong_PhanTram !== undefined ? debtRatio.TyLeNoDong_PhanTram : 29.93);
                    const tyLeNoQuaHan = debtRatio.tyLeNoQuaHan_PhanTram !== undefined ? debtRatio.tyLeNoQuaHan_PhanTram : (debtRatio.TyLeNoQuaHan_PhanTram !== undefined ? debtRatio.TyLeNoQuaHan_PhanTram : 67.8);

                    const ctx3 = document.getElementById('debtRatioChart').getContext('2d');
                    debtRatioChart = new Chart(ctx3, {
                        type: 'bar',
                        data: {
                            labels: ['Tỷ lệ nợ động', 'Tỷ lệ nợ quá hạn'],
                            datasets: [{
                                label: 'Tỷ lệ (%)',
                                data: [tyLeNoDong, tyLeNoQuaHan],
                                backgroundColor: [
                                    'rgba(239, 68, 68, 0.75)', // Red for debt ratio
                                    'rgba(245, 158, 11, 0.75)'  // Warning orange for overdue ratio
                                ],
                                borderColor: [
                                    'rgba(239, 68, 68, 1)',
                                    'rgba(245, 158, 11, 1)'
                                ],
                                borderWidth: 2,
                                borderRadius: 6,
                                barThickness: 32
                            }]
                        },
                        options: {
                            indexAxis: 'y',
                            responsive: true,
                            maintainAspectRatio: false,
                            plugins: {
                                legend: { display: false },
                                tooltip: {
                                    backgroundColor: 'rgba(255, 255, 255, 0.98)',
                                    titleColor: '#0f172a',
                                    titleFont: { size: 12, weight: 'bold' },
                                    bodyColor: '#475569',
                                    bodyFont: { size: 12, weight: '600' },
                                    borderColor: 'rgba(15, 23, 42, 0.05)',
                                    borderWidth: 1,
                                    padding: 12,
                                    callbacks: {
                                        label: function(context) {
                                            return ` ${context.label}: ${context.parsed.x}%`;
                                        }
                                    }
                                }
                            },
                            scales: {
                                x: {
                                    beginAtZero: true,
                                    max: 100,
                                    grid: {
                                        color: 'rgba(15, 23, 42, 0.04)',
                                        drawBorder: false
                                    },
                                    ticks: {
                                        font: { size: 10, weight: '700' },
                                        color: '#94a3b8',
                                        callback: function(value) {
                                            return value + '%';
                                        }
                                    }
                                },
                                y: {
                                    grid: { display: false },
                                    ticks: {
                                        font: { size: 11, weight: '700' },
                                        color: '#475569'
                                    }
                                }
                            }
                        }
                    });

                    // 2. Top Rooms Utilities Chart (Dashboard 4)
                    const ctx4 = document.getElementById('topUtilityRoomChart').getContext('2d');
                    
                    function updateUtilityChart(filterType) {
                        let processed = [];
                        if (filterType === 'All') {
                            const roomMap = {};
                            topUtilities.forEach(item => {
                                const soPhong = item.soPhong || item.SoPhong;
                                const tongTien = item.tongTien !== undefined ? item.tongTien : item.TongTien;
                                if (!roomMap[soPhong]) {
                                    roomMap[soPhong] = { soPhong: soPhong, tongTien: 0, tenDichVu: "" };
                                }
                                roomMap[soPhong].tongTien += tongTien;
                            });
                            processed = Object.values(roomMap);
                        } else {
                            processed = topUtilities
                                .filter(item => (item.tenDichVu || item.TenDichVu) === filterType)
                                .map(item => ({
                                    soPhong: item.soPhong || item.SoPhong,
                                    tongTien: item.tongTien !== undefined ? item.tongTien : item.TongTien,
                                    tenDichVu: item.tenDichVu || item.TenDichVu
                                }));
                        }
                        
                        processed.sort((a, b) => b.tongTien - a.tongTien);
                        processed = processed.slice(0, 10);
                        
                        const labels = processed.map(x => x.soPhong);
                        const values = processed.map(x => x.tongTien);
                        
                        if (topUtilityRoomChart) {
                            topUtilityRoomChart.data.labels = labels;
                            topUtilityRoomChart.data.datasets[0].data = values;
                            topUtilityRoomChart.data.datasets[0].rawItems = processed;
                            
                            let bgColors, borderColors;
                            if (filterType === 'Điện') {
                                bgColors = 'rgba(245, 158, 11, 0.75)'; // Orange/Yellow
                                borderColors = 'rgba(245, 158, 11, 1)';
                            } else if (filterType === 'Nước') {
                                bgColors = 'rgba(59, 130, 246, 0.75)'; // Blue
                                borderColors = 'rgba(59, 130, 246, 1)';
                            } else {
                                bgColors = 'rgba(16, 185, 129, 0.75)'; // Green
                                borderColors = 'rgba(16, 185, 129, 1)';
                            }
                            topUtilityRoomChart.data.datasets[0].backgroundColor = bgColors;
                            topUtilityRoomChart.data.datasets[0].borderColor = borderColors;
                            topUtilityRoomChart.update();
                        } else {
                            topUtilityRoomChart = new Chart(ctx4, {
                                type: 'bar',
                                data: {
                                    labels: labels,
                                    datasets: [{
                                        label: 'Tổng tiền',
                                        data: values,
                                        rawItems: processed,
                                        backgroundColor: 'rgba(16, 185, 129, 0.75)',
                                        borderColor: 'rgba(16, 185, 129, 1)',
                                        borderWidth: 2,
                                        borderRadius: 6,
                                        barPercentage: 0.5
                                    }]
                                },
                                options: {
                                    responsive: true,
                                    maintainAspectRatio: false,
                                    plugins: {
                                        legend: { display: false },
                                        tooltip: {
                                            backgroundColor: 'rgba(255, 255, 255, 0.98)',
                                            titleColor: '#0f172a',
                                            titleFont: { size: 12, weight: 'bold' },
                                            bodyColor: '#475569',
                                            bodyFont: { size: 12, weight: '600' },
                                            borderColor: 'rgba(15, 23, 42, 0.05)',
                                            borderWidth: 1,
                                            padding: 12,
                                            callbacks: {
                                                title: function(context) {
                                                    return `Phòng: ${context[0].label}`;
                                                },
                                                label: function(context) {
                                                    const rawItem = context.dataset.rawItems[context.dataIndex];
                                                    const serviceStr = rawItem.tenDichVu ? `Dịch vụ: ${rawItem.tenDichVu}` : `Dịch vụ: Điện & Nước`;
                                                    const moneyStr = `Tổng tiền: ${new Intl.NumberFormat('vi-VN', { style: 'currency', currency: 'VND' }).format(context.parsed.y)}`;
                                                    return [serviceStr, moneyStr];
                                                }
                                            }
                                        }
                                    },
                                    scales: {
                                        y: {
                                            beginAtZero: true,
                                            grid: {
                                                color: 'rgba(15, 23, 42, 0.04)',
                                                drawBorder: false
                                            },
                                            ticks: {
                                                font: { size: 10, weight: '700' },
                                                color: '#94a3b8',
                                                callback: function(value) {
                                                    return new Intl.NumberFormat('vi-VN', { notation: "compact", compactDisplay: "short" }).format(value);
                                                }
                                            }
                                        },
                                        x: {
                                            grid: { display: false },
                                            ticks: {
                                                font: { size: 10, weight: '700' },
                                                color: '#94a3b8'
                                            }
                                        }
                                    }
                                }
                            });
                        }
                    }
                    
                    updateUtilityChart('All');
                    
                    document.getElementById('filterUtilityType').addEventListener('change', function(e) {
                        updateUtilityChart(e.target.value);
                    });

                    // 3. Expiring Contracts Chart (Dashboard 5)
                    const ctx5 = document.getElementById('expiringContractChart').getContext('2d');
                    
                    const bubblePoints = expiringContracts.map(c => {
                        const ngayKetThucStr = c.ngayKetThuc || c.NgayKetThuc;
                        const dateObj = new Date(ngayKetThucStr);
                        const soNgayConLai = c.soNgayConLai !== undefined ? c.soNgayConLai : c.SoNgayConLai;
                        const soPhong = c.soPhong || c.SoPhong;
                        const khachDaiDien = c.khachDaiDien || c.KhachDaiDien;
                        const soDienThoai = c.soDienThoai || c.SoDienThoai;
                        const nhomCanhBao = c.nhomCanhBao || c.NhomCanhBao;

                        return {
                            x: dateObj.getTime(), 
                            y: soNgayConLai,
                            r: Math.max(8, 25 - soNgayConLai / 3), 
                            soPhong: soPhong,
                            khachDaiDien: khachDaiDien,
                            soDienThoai: soDienThoai,
                            ngayKetThuc: dateObj.toLocaleDateString('vi-VN'),
                            soNgayConLai: soNgayConLai,
                            nhomCanhBao: nhomCanhBao
                        };
                    });
                    
                    const bubbleBackgrounds = bubblePoints.map(p => 
                        p.soNgayConLai <= 30 ? 'rgba(239, 68, 68, 0.75)' : 'rgba(245, 158, 11, 0.75)'
                    );
                    const bubbleBorders = bubblePoints.map(p => 
                        p.soNgayConLai <= 30 ? 'rgba(239, 68, 68, 1)' : 'rgba(245, 158, 11, 1)'
                    );
                    
                    expiringContractChart = new Chart(ctx5, {
                        type: 'bubble',
                        data: {
                            datasets: [{
                                label: 'Hợp đồng sắp hết hạn',
                                data: bubblePoints,
                                backgroundColor: bubbleBackgrounds,
                                borderColor: bubbleBorders,
                                borderWidth: 2,
                                hoverRadius: 2
                            }]
                        },
                        options: {
                            responsive: true,
                            maintainAspectRatio: false,
                            plugins: {
                                legend: { display: false },
                                tooltip: {
                                    backgroundColor: 'rgba(255, 255, 255, 0.98)',
                                    titleColor: '#0f172a',
                                    titleFont: { size: 12, weight: 'bold' },
                                    bodyColor: '#475569',
                                    bodyFont: { size: 12, weight: '600' },
                                    borderColor: 'rgba(15, 23, 42, 0.05)',
                                    borderWidth: 1,
                                    padding: 12,
                                    callbacks: {
                                        title: function(context) {
                                            const item = context[0].raw;
                                            return `Phòng: ${item.soPhong}`;
                                        },
                                        label: function(context) {
                                            const item = context.raw;
                                            return [
                                                `Khách: ${item.khachDaiDien}`,
                                                `SĐT: ${item.soDienThoai}`,
                                                `Ngày kết thúc: ${item.ngayKetThuc}`,
                                                `Số ngày còn lại: ${item.soNgayConLai} ngày`,
                                                `Cảnh báo: ${item.nhomCanhBao}`
                                            ];
                                        }
                                    }
                                }
                            },
                            scales: {
                                x: {
                                    type: 'linear',
                                    grid: {
                                        color: 'rgba(15, 23, 42, 0.04)'
                                    },
                                    ticks: {
                                        font: { size: 9, weight: '700' },
                                        color: '#94a3b8',
                                        callback: function(value) {
                                            return new Date(value).toLocaleDateString('vi-VN', { month: '2-digit', day: '2-digit' });
                                        }
                                    },
                                    title: {
                                        display: true,
                                        text: 'Ngày kết thúc',
                                        font: { size: 10, weight: 'bold' },
                                        color: '#64748b'
                                    }
                                },
                                y: {
                                    beginAtZero: true,
                                    max: 70,
                                    grid: {
                                        color: 'rgba(15, 23, 42, 0.04)'
                                    },
                                    ticks: {
                                        font: { size: 10, weight: '700' },
                                        color: '#94a3b8'
                                    },
                                    title: {
                                        display: true,
                                        text: 'Số ngày còn lại',
                                        font: { size: 10, weight: 'bold' },
                                        color: '#64748b'
                                    }
                                }
                            }
                        }
                    });
                    
                    // Render table below/beside the chart
                    const tableBody = document.querySelector('#expiringContractsTable tbody');
                    if (tableBody) {
                        tableBody.innerHTML = '';
                        if (expiringContracts.length === 0) {
                            tableBody.innerHTML = '<tr><td colspan="6" class="text-center text-muted py-4">Không có hợp đồng nào sắp hết hạn.</td></tr>';
                        } else {
                            expiringContracts.forEach(c => {
                                const soNgayConLai = c.soNgayConLai !== undefined ? c.soNgayConLai : c.SoNgayConLai;
                                const soPhong = c.soPhong || c.SoPhong;
                                const khachDaiDien = c.khachDaiDien || c.KhachDaiDien;
                                const soDienThoai = c.soDienThoai || c.SoDienThoai;
                                const ngayKetThucStr = c.ngayKetThuc || c.NgayKetThuc;
                                const nhomCanhBao = c.nhomCanhBao || c.NhomCanhBao;
                                
                                const isCritical = soNgayConLai <= 30;
                                const badgeClass = isCritical ? 'bg-danger bg-opacity-10 text-danger border border-danger border-opacity-10' : 'bg-warning bg-opacity-10 text-warning border border-warning border-opacity-10';
                                const row = `
                                    <tr>
                                        <td class="fw-700 text-dark">${soPhong}</td>
                                        <td class="fw-600">${khachDaiDien}</td>
                                        <td class="text-secondary small font-monospace">${soDienThoai}</td>
                                        <td class="text-secondary small">${new Date(ngayKetThucStr).toLocaleDateString('vi-VN')}</td>
                                        <td class="text-end fw-700 ${isCritical ? 'text-danger' : 'text-warning'}">${soNgayConLai} ngày</td>
                                        <td class="text-center">
                                            <span class="badge rounded-pill fw-700 px-2.5 py-1 ${badgeClass}">${nhomCanhBao}</span>
                                        </td>
                                    </tr>
                                `;
                                tableBody.insertAdjacentHTML('beforeend', row);
                            });
                        }
                    }
                })
                .catch(error => console.error('Error fetching extra charts data:', error));
        });
    </script>
}

