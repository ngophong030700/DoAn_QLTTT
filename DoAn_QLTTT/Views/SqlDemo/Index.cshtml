@model SqlDemoPageViewModel
@using System.Text.Json
@using System.Text.RegularExpressions
@{
    ViewData["Title"] = "Demo SQL";
    var scenario = Model.SelectedScenario;
    var selectedIndex = scenario is null ? -1 : Model.Scenarios.ToList().FindIndex(x => x.Id == scenario.Id);
}

@functions {
    private string GetScenarioIcon(string id)
    {
        return id switch
        {
            "them-khach-thue" => "bi-person-plus-fill",
            "lap-hop-dong" => "bi-file-earmark-medical-fill",
            "ghi-chi-so" => "bi-lightning-charge-fill",
            "lap-hoa-don-thang" => "bi-receipt",
            "ghi-nhan-thanh-toan" => "bi-wallet2",
            "tinh-cong-no-hop-dong" => "bi-calculator-fill",
            "quet-hoa-don-qua-han" => "bi-bell-fill",
            "quet-hop-dong-het-han" => "bi-shield-check-fill",
            _ => "bi-database-fill"
        };
    }

    private string GetBadgeClass(string type)
    {
        if (type.Contains("Procedure") && type.Contains("Trigger") && type.Contains("Function")) return "bg-dark-subtle text-dark border-dark-subtle";
        if (type.Contains("Procedure") && type.Contains("Trigger")) return "bg-primary-subtle text-primary border-primary-subtle";
        if (type.Contains("Cursor")) return "bg-warning-subtle text-warning border-warning-subtle";
        if (type.Contains("Procedure")) return "bg-success-subtle text-success border-success-subtle";
        if (type.Contains("Function")) return "bg-info-subtle text-info border-info-subtle";
        return "bg-light text-secondary border-secondary-subtle";
    }

    private string GetSqlValue(string sql, string pattern, string fallback = "")
    {
        var match = Regex.Match(sql, pattern, RegexOptions.IgnoreCase | RegexOptions.Multiline);
        return match.Success ? match.Groups["value"].Value.Replace("''", "'") : fallback;
    }

    private string GetExecuteButtonLabel(string id)
    {
        return id switch
        {
            "them-khach-thue" => "Thêm khách thuê",
            "lap-hop-dong" => "Lập hợp đồng",
            "ghi-chi-so" => "Ghi chỉ số",
            "lap-hoa-don-thang" => "Lập hóa đơn",
            "ghi-nhan-thanh-toan" => "Ghi nhận thanh toán",
            "tinh-cong-no-hop-dong" => "Xem nợ",
            "quet-hoa-don-qua-han" => "Quét hóa đơn",
            "quet-hop-dong-het-han" => "Quét hợp đồng",
            _ => "Thực thi"
        };
    }

    private string GetSuccessLabel(string id)
    {
        return id switch
        {
            "them-khach-thue" => "Đã thêm khách thuê thành công",
            "lap-hop-dong" => "Đã lập hợp đồng thành công",
            "ghi-chi-so" => "Đã ghi chỉ số thành công",
            "lap-hoa-don-thang" => "Đã lập hóa đơn thành công",
            "ghi-nhan-thanh-toan" => "Đã ghi nhận thanh toán thành công",
            "tinh-cong-no-hop-dong" => "Đã tính công nợ thành công",
            "quet-hoa-don-qua-han" => "Đã quét hóa đơn thành công",
            "quet-hop-dong-het-han" => "Đã quét hợp đồng thành công",
            _ => "Đã thực thi thành công"
        };
    }
}

<div class="sql-demo-page container-fluid px-0">
    <div class="row g-4">
        <!-- Sidebar: Roadmap Stepper -->
        <div class="col-12 col-xl-3">
            <div class="sql-demo-panel sql-demo-sticky shadow-sm rounded-4 p-3 border">
                <div class="sql-demo-panel-header pb-3 mb-3 border-bottom d-flex align-items-center justify-content-between">
                    <div>
                        <span class="sql-demo-eyebrow text-primary">Kịch bản</span>
                        <h2 class="h5 fw-800 text-dark mb-0">8 Bước Nghiệp Vụ</h2>
                    </div>
                </div>
                <div class="sql-demo-flow position-relative">
                    @for (var index = 0; index < Model.Scenarios.Count; index++)
                    {
                        var item = Model.Scenarios[index];
                        var active = scenario?.Id == item.Id;
                        var completed = index < selectedIndex;
                        <a class="sql-demo-flow-item d-flex align-items-center gap-3 p-2.5 rounded-3 mb-2 transition-all text-decoration-none @(active ? "active shadow-sm" : "") @(completed ? "completed" : "")"
                           asp-controller="SqlDemo"
                           asp-action="Index"
                           asp-route-id="@item.Id">
                            <div class="sql-demo-step-icon-wrap d-flex align-items-center justify-content-center rounded-circle flex-shrink-0">
                                @if (completed)
                                {
                                    <i class="bi bi-check-lg"></i>
                                }
                                else
                                {
                                    <span class="step-num">@(index + 1)</span>
                                }
                            </div>
                            <div class="flex-grow-1 overflow-hidden">
                                <strong class="d-block text-truncate">@item.Title</strong>
                                <span class="badge text-xxs border mt-1 @GetBadgeClass(item.Type)">@item.Type</span>
                            </div>
                            <div class="flow-arrow text-muted opacity-50 ms-auto">
                                <i class="bi @(active ? "bi-chevron-right text-primary opacity-100" : "bi-chevron-right")"></i>
                            </div>
                        </a>
                    }
                </div>
            </div>
        </div>

        <!-- Main Workspace -->
        <div class="col-12 col-xl-9">
            @if (scenario is not null)
            {
                <!-- Active Scenario Header -->
                <div class="sql-demo-panel mb-4 shadow-sm rounded-4 p-4 border bg-white">
                    <div class="sql-demo-scenario-head d-flex align-items-center justify-content-between gap-3 flex-wrap">
                        <div class="d-flex align-items-center gap-3">
                            <div class="scenario-icon-box bg-primary bg-opacity-10 text-primary d-flex align-items-center justify-content-center rounded-3" style="width: 54px; height: 54px;">
                                <i class="bi @GetScenarioIcon(scenario.Id) fs-3"></i>
                            </div>
                            <div>
                                <div class="d-flex align-items-center gap-2 flex-wrap">
                                    <span class="badge bg-primary px-2 py-1 fs-8 text-uppercase">Bước @(selectedIndex + 1)</span>
                                    <span class="badge border @GetBadgeClass(scenario.Type) px-2 py-1 fs-8">@scenario.Type</span>
                                </div>
                                <h2 class="h3 fw-800 text-dark mt-1 mb-0">@scenario.Title</h2>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Step Cards Grid -->
                <div class="sql-demo-grid">
                    <!-- B1: Problem Scenario -->
                    <div class="sql-demo-step-card shadow-sm rounded-4 p-4 border bg-white">
                        <div class="sql-demo-step-title border-bottom pb-3 mb-3 d-flex align-items-center gap-2">
                            <h3 class="h6 text-dark fw-800 mb-0"><i class="bi bi-chat-left-quote-fill text-muted me-1"></i>Yêu cầu nghiệp vụ & Bài toán đặt ra</h3>
                        </div>
                        <div class="p-3 bg-light rounded-3 border-start border-primary border-3 mb-3">
                            <p class="fw-700 text-dark mb-0 fs-6 leading-relaxed">@scenario.Problem</p>
                        </div>
                        <div class="text-secondary small d-flex align-items-start gap-2">
                            <i class="bi bi-info-circle-fill text-primary mt-0.5"></i>
                            <span><strong>Chú thích giải pháp SQL:</strong> @scenario.Note</span>
                        </div>
                    </div>

                    <!-- B2: Scenario parameters and generated SQL -->
                    <div class="sql-demo-step-card shadow-sm rounded-4 p-4 border bg-white">
                        <div class="sql-demo-step-title border-bottom pb-3 mb-3">
                            <div class="d-flex align-items-center justify-content-between gap-2">
                                <div class="d-flex align-items-center gap-2">
                                    <h3 class="h6 text-dark fw-800 mb-0"><i class="bi bi-code-slash text-muted me-1"></i>Tham số kịch bản & câu truy vấn SQL</h3>
                                </div>
                                <div class="d-flex align-items-center gap-2">
                                    <button type="button" class="btn btn-sm btn-outline-secondary d-flex align-items-center gap-1" id="btn-reset-sql" title="Xóa dữ liệu đã nhập">
                                        <i class="bi bi-arrow-counterclockwise"></i> Làm mới
                                    </button>
                                    <button class="btn btn-sm btn-primary d-flex align-items-center gap-1" type="submit" form="sql-demo-execute-form">
                                        <i class="bi bi-play-fill"></i> @GetExecuteButtonLabel(scenario.Id)
                                    </button>
                                </div>
                            </div>
                            @if (scenario.HasExecuted)
                            {
                                if (string.IsNullOrWhiteSpace(scenario.ErrorMessage))
                                {
                                    <div id="sql-demo-success-message" class="text-success small fw-700 text-end mt-2">
                                        <i class="bi bi-check2-all me-1"></i>@GetSuccessLabel(scenario.Id)
                                    </div>
                                }
                                else
                                {
                                    <div id="sql-demo-error-message" class="text-danger small fw-700 text-end mt-2">
                                        <i class="bi bi-exclamation-triangle-fill me-1"></i>@scenario.ErrorMessage
                                    </div>
                                }
                            }
                        </div>

                        <form id="sql-demo-execute-form" asp-controller="SqlDemo" asp-action="Execute" method="post">
                            <input type="hidden" name="id" value="@scenario.Id" />
                            <div class="row g-3 sql-demo-builder">
                                <div class="col-12 col-lg-4">
                                    <div class="sql-parameter-panel h-100 rounded-3 border bg-light p-3">
                                        <div class="fw-800 text-dark mb-1">Giá trị kịch bản</div>
                                        <p class="small text-secondary mb-3">Thay đổi giá trị để tự động tạo lại câu SQL.</p>
                                        <div id="sql-parameter-form" class="d-grid gap-3">
                                            @switch (scenario.Id)
                                            {
                                                case "them-khach-thue":
                                                    <div><label class="form-label">Họ tên</label><input id="param-ho-ten" class="form-control sql-param" value="@(scenario.HasExecuted ? GetSqlValue(scenario.SqlScript, @"@HoTen\s*=\s*N'(?<value>(?:''|[^'])*)'") : "")" placeholder="Ví dụ: Nguyễn Văn Demo" required /></div>
                                                    <div><label class="form-label">CCCD</label><input id="param-cccd" class="form-control sql-param" value="@(scenario.HasExecuted ? GetSqlValue(scenario.SqlScript, @"@CCCD\s*=\s*'(?<value>(?:''|[^'])*)'") : "")" placeholder="Ví dụ: 079199999999" required /></div>
                                                    <div><label class="form-label">Số điện thoại</label><input id="param-so-dien-thoai" class="form-control sql-param" value="@(scenario.HasExecuted ? GetSqlValue(scenario.SqlScript, @"@SoDienThoai\s*=\s*'(?<value>(?:''|[^'])*)'") : "")" placeholder="Ví dụ: 0909999999" /></div>
                                                    <div><label class="form-label">Địa chỉ</label><input id="param-dia-chi" class="form-control sql-param" value="@(scenario.HasExecuted ? GetSqlValue(scenario.SqlScript, @"@DiaChi\s*=\s*N'(?<value>(?:''|[^'])*)'") : "")" placeholder="Ví dụ: TP.HCM" /></div>
                                                    break;
                                                case "lap-hop-dong":
                                                    {
                                                        var selectedRoom = GetSqlValue(scenario.SqlScript, @"DECLARE\s+@MaPhong\s+INT\s*=\s*(?<value>\d+)", "");
                                                        var selectedCustomer = scenario.HasExecuted
                                                            ? GetSqlValue(scenario.SqlScript, @"DECLARE\s+@MaKhachDaiDien\s+INT\s*=\s*(?<value>\d+)", "")
                                                            : scenario.PreferredCustomerId?.ToString() ?? "";
                                                        var startDate = scenario.HasExecuted
                                                            ? GetSqlValue(scenario.SqlScript, @"@NgayBatDau\s*=\s*'(?<value>[^']*)'")
                                                            : DateTime.Today.ToString("yyyy-MM-dd");
                                                        var endDate = scenario.HasExecuted
                                                            ? GetSqlValue(scenario.SqlScript, @"@NgayKetThuc\s*=\s*'(?<value>[^']*)'")
                                                            : DateTime.Today.AddYears(1).ToString("yyyy-MM-dd");
                                                        <div>
                                                            <label class="form-label">Phòng cho thuê</label>
                                                            <select id="param-ma-phong" class="form-select sql-param" required>
                                                                <option value="">Chọn phòng đang trống</option>
                                                                @foreach (var option in scenario.RoomOptions)
                                                                {
                                                                    <option value="@option.Value" selected="@(option.Value.ToString() == selectedRoom ? "selected" : null)">@option.Label</option>
                                                                }
                                                            </select>
                                                        </div>
                                                        <div>
                                                            <label class="form-label">Khách đại diện</label>
                                                            <select id="param-ma-khach" class="form-select sql-param" required>
                                                                <option value="">Chọn khách thuê</option>
                                                                @foreach (var option in scenario.CustomerOptions)
                                                                {
                                                                    <option value="@option.Value" selected="@(option.Value.ToString() == selectedCustomer ? "selected" : null)">@option.Label</option>
                                                                }
                                                            </select>
                                                        </div>
                                                        <div><label class="form-label">Ngày bắt đầu</label><input id="param-ngay-bat-dau" type="date" class="form-control sql-param" value="@startDate" required /></div>
                                                        <div><label class="form-label">Ngày kết thúc</label><input id="param-ngay-ket-thuc" type="date" class="form-control sql-param" value="@endDate" required /></div>
                                                        <div><label class="form-label">Tiền đặt cọc</label><input id="param-tien-coc" type="number" min="0" step="100000" class="form-control sql-param" value="@(scenario.HasExecuted ? GetSqlValue(scenario.SqlScript, @"@TienCoc\s*=\s*(?<value>\d+)") : "")" placeholder="Ví dụ: 3000000" required /></div>
                                                        <div class="form-text"><i class="bi bi-info-circle me-1"></i>Giá thuê hằng tháng tự động lấy theo cấu hình gốc của phòng.</div>
                                                    }
                                                    break;
                                                case "ghi-chi-so":
                                                    {
                                                        var selectedRoom = GetSqlValue(scenario.SqlScript, @"DECLARE\s+@MaPhong\s+INT\s*=\s*(?<value>\d+)", "");
                                                        var selectedService = GetSqlValue(scenario.SqlScript, @"DECLARE\s+@MaDichVu\s+INT\s*=\s*(?<value>\d+)", "");
                                                        var selectedMonth = scenario.HasExecuted
                                                            ? $"{GetSqlValue(scenario.SqlScript, @"@Nam\s*=\s*(?<value>\d+)", DateTime.Today.Year.ToString())}-{GetSqlValue(scenario.SqlScript, @"@Thang\s*=\s*(?<value>\d+)", DateTime.Today.Month.ToString()).PadLeft(2, '0')}"
                                                            : DateTime.Today.ToString("yyyy-MM");
                                                        <div>
                                                            <label class="form-label">Phòng cần ghi</label>
                                                            <select id="param-ma-phong" class="form-select sql-param" required>
                                                                <option value="">Chọn phòng đang thuê</option>
                                                                @foreach (var option in scenario.RoomOptions)
                                                                {
                                                                    <option value="@option.Value" selected="@(option.Value.ToString() == selectedRoom ? "selected" : null)">@option.Label</option>
                                                                }
                                                            </select>
                                                        </div>
                                                        <div>
                                                            <label class="form-label">Loại dịch vụ</label>
                                                            <select id="param-ma-dich-vu" class="form-select sql-param" required>
                                                                <option value="">Chọn Điện/Nước</option>
                                                                @foreach (var option in scenario.ServiceOptions)
                                                                {
                                                                    <option value="@option.Value" selected="@(option.Value.ToString() == selectedService ? "selected" : null)">@option.Label</option>
                                                                }
                                                            </select>
                                                        </div>
                                                        <div><label class="form-label">Kỳ tháng/năm</label><input id="param-ky" type="month" class="form-control sql-param" value="@selectedMonth" required /></div>
                                                        <div><label class="form-label">Chỉ số cũ</label><input id="param-chi-so-cu" type="number" class="form-control" value="0" readonly /></div>
                                                        <div><label class="form-label">Chỉ số mới</label><input id="param-chi-so-moi" type="number" min="0" class="form-control sql-param" value="@(scenario.HasExecuted ? GetSqlValue(scenario.SqlScript, @"DECLARE\s+@ChiSoMoi\s+INT\s*=\s*(?<value>\d+)") : "")" placeholder="Nhập chỉ số công tơ hiện tại" required /></div>
                                                        <div class="form-text"><i class="bi bi-info-circle me-1"></i>Chỉ số cũ và lượng tiêu thụ sẽ được hệ thống tự động tính toán.</div>
                                                    }
                                                    break;
                                                case "lap-hoa-don-thang":
                                                    {
                                                        var selectedContract = GetSqlValue(scenario.SqlScript, @"DECLARE\s+@MaHopDong\s+INT\s*=\s*(?<value>\d+)", "");
                                                        var selectedMonth = scenario.HasExecuted ? GetSqlValue(scenario.SqlScript, @"@Thang\s*=\s*(?<value>\d+)") : DateTime.Today.Month.ToString();
                                                        <div>
                                                            <label class="form-label">Hợp đồng hiệu lực</label>
                                                            <select id="param-ma-hop-dong" class="form-select sql-param" required>
                                                                <option value="">Chọn hợp đồng</option>
                                                                @foreach (var option in scenario.ContractOptions)
                                                                {
                                                                    <option value="@option.Value" selected="@(option.Value.ToString() == selectedContract ? "selected" : null)">@option.Label</option>
                                                                }
                                                            </select>
                                                        </div>
                                                        <div>
                                                            <label class="form-label">Tháng xuất hóa đơn</label>
                                                            <select id="param-thang" class="form-select sql-param" required>
                                                                @for (var month = 1; month <= 12; month++)
                                                                {
                                                                    <option value="@month" selected="@(month.ToString() == selectedMonth ? "selected" : null)">Tháng @month</option>
                                                                }
                                                            </select>
                                                        </div>
                                                        <div><label class="form-label">Năm xuất hóa đơn</label><input id="param-nam" type="number" min="2000" max="2100" class="form-control sql-param" value="@(scenario.HasExecuted ? GetSqlValue(scenario.SqlScript, @"@Nam\s*=\s*(?<value>\d+)") : DateTime.Today.Year)" required /></div>
                                                        <div class="form-text"><i class="bi bi-info-circle me-1"></i>Tổng tiền sẽ được hệ thống tự động gom từ tiền phòng và điện nước.</div>
                                                    }
                                                    break;
                                                case "ghi-nhan-thanh-toan":
                                                    {
                                                        var selectedInvoice = GetSqlValue(scenario.SqlScript, @"DECLARE\s+@MaHoaDon\s+INT\s*=\s*(?<value>\d+)", "");
                                                        <div>
                                                            <label class="form-label">Hóa đơn còn nợ</label>
                                                            <select id="param-ma-hoa-don" class="form-select sql-param" required>
                                                                <option value="">Chọn hóa đơn</option>
                                                                @foreach (var option in scenario.InvoiceOptions)
                                                                {
                                                                    <option value="@option.Value"
                                                                            data-debt="@option.Amount"
                                                                            selected="@(option.Value.ToString() == selectedInvoice ? "selected" : null)">@option.Label</option>
                                                                }
                                                            </select>
                                                        </div>
                                                        <div><label class="form-label">Ngày thu tiền</label><input id="param-ngay-thu" type="date" class="form-control sql-param" value="@(scenario.HasExecuted ? GetSqlValue(scenario.SqlScript, @"@NgayThu\s*=\s*'(?<value>[^']*)'") : DateTime.Today.ToString("yyyy-MM-dd"))" required /></div>
                                                        <div><label class="form-label">Số tiền đóng</label><input id="param-so-tien" type="number" min="1" step="1000" class="form-control sql-param" value="@(scenario.HasExecuted ? GetSqlValue(scenario.SqlScript, @"DECLARE\s+@SoTienThanhToan\s+DECIMAL\(18,0\)\s*=\s*(?<value>\d+)") : "")" placeholder="Nhập số tiền khách đóng" required /></div>
                                                        <div class="form-text" id="payment-debt-note">Chọn hóa đơn để xem số nợ còn lại.</div>
                                                        <div><label class="form-label">Hình thức thanh toán</label><select id="param-hinh-thuc" class="form-select sql-param" required><option value="">Chọn hình thức</option><option value="TienMat">Tiền mặt</option><option value="ChuyenKhoan">Chuyển khoản</option></select></div>
                                                    }
                                                    break;
                                                case "tinh-cong-no-hop-dong":
                                                    {
                                                        var selectedContract = GetSqlValue(scenario.SqlScript, @"DECLARE\s+@MaHopDong\s+INT\s*=\s*(?<value>\d+)", "");
                                                        <div>
                                                            <label class="form-label">Hợp đồng</label>
                                                            <select id="param-ma-hop-dong" class="form-select sql-param" required>
                                                                <option value="">Chọn hợp đồng cần xem nợ</option>
                                                                @foreach (var option in scenario.ContractOptions)
                                                                {
                                                                    <option value="@option.Value" selected="@(option.Value.ToString() == selectedContract ? "selected" : null)">@option.Label</option>
                                                                }
                                                            </select>
                                                        </div>
                                                    }
                                                    break;
                                                case "quet-hoa-don-qua-han":
                                                case "quet-hop-dong-het-han":
                                                    <div>
                                                        <label class="form-label">Ngày quét dữ liệu</label>
                                                        <input id="param-ngay-quet" type="date" class="form-control sql-param" value="@GetSqlValue(scenario.SqlScript, @"<\s*'(?<value>\d{4}-\d{2}-\d{2})'", "")" />
                                                        <div class="form-text">Để trống để sử dụng ngày hiện tại của SQL Server.</div>
                                                    </div>
                                                    break;
                                            }
                                        </div>
                                    </div>
                                </div>
                                <div class="col-12 col-lg-8">
                                    <div class="sql-editor-container rounded-3 overflow-hidden shadow h-100">
                                        <div class="sql-editor-header d-flex align-items-center justify-content-between px-3 py-2 bg-dark">
                                            <div class="mac-controls d-flex align-items-center gap-1.5">
                                                <span class="control-dot close"></span>
                                                <span class="control-dot minimize"></span>
                                                <span class="control-dot maximize"></span>
                                            </div>
                                            <div class="editor-tab-indicator font-monospace small" style="color: rgba(255, 255, 255, 0.8) !important;">
                                                <i class="bi bi-filetype-sql text-warning me-1"></i>@scenario.Id.Replace("-", "_")_script.sql
                                            </div>
                                            <div class="small" style="color: rgba(255, 255, 255, 0.6) !important;">Chỉ xem</div>
                                        </div>
                                        <textarea class="sql-demo-code sql-demo-editor font-monospace"
                                                  id="sqlScriptTextarea"
                                                  name="sqlScript"
                                                  readonly
                                                  spellcheck="false">@scenario.SqlScript</textarea>
                                    </div>
                                </div>
                            </div>
                        </form>
                    </div>

                    <!-- B3: Before State Data -->
                    <div class="sql-demo-step-card shadow-sm rounded-4 p-4 border bg-white">
                        <div class="sql-demo-step-title border-bottom pb-3 mb-3 d-flex align-items-center justify-content-between gap-2">
                            <h3 class="h6 text-dark fw-800 mb-0"><i class="bi bi-table text-muted me-1"></i>Dữ liệu hiện trạng (Trước khi chạy)</h3>
                            <a class="btn btn-sm btn-outline-primary d-flex align-items-center gap-1"
                               id="btn-reload-current-data"
                               asp-controller="SqlDemo"
                               asp-action="Index"
                               asp-route-id="@scenario.Id"
                               title="Tải lại dữ liệu mới nhất">
                                <i class="bi bi-arrow-clockwise"></i> Reload
                            </a>
                        </div>
                        <div class="sql-table-wrapper">
                            @await Html.PartialAsync("_SqlDemoTables", scenario.BeforeTables)
                        </div>
                    </div>

                    <!-- B4: After State Data & Logs -->
                    <div class="sql-demo-step-card shadow-sm rounded-4 p-4 border bg-white">
                        <div class="sql-demo-step-title border-bottom pb-3 mb-3 d-flex align-items-center gap-2">
                            <h3 class="h6 text-dark fw-800 mb-0"><i class="bi bi-terminal-fill text-muted me-1"></i>Trạng thái kết quả & Dữ liệu đầu ra (Sau khi chạy)</h3>
                        </div>

                        @if (!scenario.HasExecuted)
                        {
                            <div class="sql-demo-result sql-demo-result-idle p-4 text-center rounded-3 border-dashed mb-4 d-flex flex-column align-items-center justify-content-center py-5">
                                <div class="sql-demo-result-icon bg-light text-primary rounded-circle d-flex align-items-center justify-content-center mb-3 shadow-sm" style="width: 58px; height: 58px;">
                                    <i class="bi bi-play-circle-fill fs-2"></i>
                                </div>
                                <h4 class="h6 fw-800 text-dark mb-1">Hệ thống đang chờ lệnh</h4>
                                <p class="text-secondary small mb-0 max-w-450">Hãy nhập tham số và nhấn <strong>@GetExecuteButtonLabel(scenario.Id)</strong> để gửi script lên Server.</p>
                            </div>
                        }
                        else
                        {
                           @*  @if (!string.IsNullOrWhiteSpace(scenario.OutputTitle) || !string.IsNullOrWhiteSpace(scenario.OutputMessage))
                            {
                                <div class="sql-demo-result sql-demo-result-success shadow-sm">
                                    <div class="sql-demo-result-icon">
                                        <i class="bi bi-check-circle-fill fs-4"></i>
                                    </div>
                                    <div class="flex-grow-1">
                                        <h4 class="sql-demo-result-title text-success fw-800 fs-6 mb-1">
                                            @(string.IsNullOrWhiteSpace(scenario.OutputTitle) ? "Thực thi thành công" : scenario.OutputTitle)
                                        </h4>
                                        @if (!string.IsNullOrWhiteSpace(scenario.OutputMessage))
                                        {
                                            <div class="sql-demo-result-message text-secondary small mt-1">@scenario.OutputMessage</div>
                                        }
                                    </div>
                                </div>
                            } *@
                            @if (scenario.CreatedCustomerId.HasValue)
                            {
                                <div class="alert alert-info border-0 bg-info bg-opacity-10 text-info-emphasis">
                                    Mã khách vừa tạo:
                                    <strong class="fs-5 ms-1">#@scenario.CreatedCustomerId.Value</strong>
                                    <span class="d-block small mt-1">Mã khách này sẽ được ưu tiên chọn khi chuyển sang bước Lập hợp đồng.</span>
                                </div>
                            }
                            @if (scenario.Id == "tinh-cong-no-hop-dong" && scenario.DebtAmount.HasValue)
                            {
                                <div class="text-center p-4 bg-light rounded-3 border mb-4">
                                    <div class="text-secondary small mb-1">Tổng công nợ còn lại</div>
                                    <div class="display-6 fw-800 text-danger">@FormatHelper.Money(scenario.DebtAmount.Value)</div>
                                </div>
                            }
                            <div class="sql-demo-result-data-title mt-2 mb-3 fw-800 text-uppercase tracking-wider small text-secondary d-flex align-items-center gap-1.5 border-bottom pb-2">
                                <i class="bi bi-database-check text-success fs-5"></i> Dữ liệu sau biến động (Sau khi chạy)
                            </div>
                            <div class="sql-table-wrapper">
                                @await Html.PartialAsync("_SqlDemoTables", scenario.AfterTables)
                            </div>
                        }
                    </div>
                </div>
            }
            else
            {
                <div class="sql-demo-panel shadow-sm rounded-4 p-5 text-center bg-white border">
                    <i class="bi bi-database-fill-gear text-primary opacity-25 display-1 mb-4"></i>
                    <h3 class="h4 fw-800 text-dark">Hãy chọn một kịch bản</h3>
                    <p class="text-secondary mb-0">Chọn một trong các bước nghiệp vụ ở sidebar bên trái để xem chi tiết luồng dữ liệu.</p>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            var textarea = document.getElementById("sqlScriptTextarea");
            var scenarioId = @Html.Raw(JsonSerializer.Serialize(scenario?.Id));
            var hasExecuted = @Html.Raw(JsonSerializer.Serialize(scenario?.HasExecuted ?? false));
            var currentUserId = @Html.Raw(JsonSerializer.Serialize(scenario?.CurrentUserId ?? 1));
            var originalSql = @Html.Raw(JsonSerializer.Serialize(scenario?.SqlScript ?? ""));
            var reloadScrollKey = "sql-demo-reload-scroll";
            var savedScrollPosition = sessionStorage.getItem(reloadScrollKey);

            if (savedScrollPosition !== null) {
                sessionStorage.removeItem(reloadScrollKey);
                requestAnimationFrame(function() {
                    window.scrollTo(0, Number(savedScrollPosition));
                });
            }

            $("#btn-reload-current-data").on("click", function() {
                sessionStorage.setItem(reloadScrollKey, String(window.scrollY));
            });

            if (scenarioId === "ghi-nhan-thanh-toan" && hasExecuted) {
                var methodMatch = originalSql.match(/@@HinhThuc\s*=\s*'((?:''|[^'])*)'/i);
                var currentMethod = methodMatch ? methodMatch[1].replace(/''/g, "'") : "ChuyenKhoan";
                $("#param-hinh-thuc").val(currentMethod);
            }

            function sqlString(value, unicode) {
                return (unicode ? "N'" : "'") + String(value || "").replace(/'/g, "''") + "'";
            }

            function sqlOptionalString(value, unicode) {
                return String(value || "").trim() ? sqlString(value, unicode) : "NULL";
            }

            function numberValue(id, fallback) {
                var value = document.getElementById(id)?.value;
                return /^\d+$/.test(value || "") ? value : fallback;
            }

            function replaceValue(sql, pattern, value) {
                return sql.replace(pattern, function(_, prefix) {
                    return prefix + value;
                });
            }

            function updateSql() {
                if (!textarea) return;

                var sql = originalSql;
                switch (scenarioId) {
                    case "them-khach-thue":
                        sql = replaceValue(sql, /(@@HoTen\s*=\s*)N'(?:''|[^'])*'/i, sqlString($("#param-ho-ten").val(), true));
                        sql = replaceValue(sql, /(@@CCCD\s*=\s*)'(?:''|[^'])*'/i, sqlString($("#param-cccd").val(), false));
                        sql = replaceValue(sql, /(@@SoDienThoai\s*=\s*)(?:NULL|'(?:''|[^'])*')/i, sqlOptionalString($("#param-so-dien-thoai").val(), false));
                        sql = replaceValue(sql, /(@@DiaChi\s*=\s*)(?:NULL|N'(?:''|[^'])*')/i, sqlOptionalString($("#param-dia-chi").val(), true));
                        break;
                    case "lap-hop-dong":
                        sql = replaceValue(sql, /(DECLARE\s+@@MaPhong\s+INT\s*=\s*)\d+/i, numberValue("param-ma-phong", "0"));
                        sql = replaceValue(sql, /(DECLARE\s+@@MaKhachDaiDien\s+INT\s*=\s*)\d+/i, numberValue("param-ma-khach", "0"));
                        sql = replaceValue(sql, /(@@NgayBatDau\s*=\s*)'[^']*'/i, sqlString($("#param-ngay-bat-dau").val(), false));
                        sql = replaceValue(sql, /(@@NgayKetThuc\s*=\s*)'[^']*'/i, sqlString($("#param-ngay-ket-thuc").val(), false));
                        sql = replaceValue(sql, /(@@TienCoc\s*=\s*)\d+/i, numberValue("param-tien-coc", ""));
                        break;
                    case "ghi-chi-so":
                        var period = ($("#param-ky").val() || "").split("-");
                        var year = period[0] || "";
                        var month = period[1] ? String(Number(period[1])) : "";
                        sql = replaceValue(sql, /(DECLARE\s+@@MaPhong\s+INT\s*=\s*)\d+/i, numberValue("param-ma-phong", "0"));
                        sql = replaceValue(sql, /(DECLARE\s+@@MaDichVu\s+INT\s*=\s*)\d+/i, numberValue("param-ma-dich-vu", "0"));
                        sql = replaceValue(sql, /(DECLARE\s+@@ChiSoMoi\s+INT\s*=\s*)\d+/i, numberValue("param-chi-so-moi", "0"));
                        sql = replaceValue(sql, /(@@MaNguoiNhap\s*=\s*)\d+/i, String(currentUserId));
                        sql = replaceValue(sql, /(@@Thang\s*=\s*)\d+/i, month);
                        sql = replaceValue(sql, /(@@Nam\s*=\s*)\d+/i, year);
                        sql = sql.replace(/DATEFROMPARTS\(\d+,\s*\d+,\s*1\)/i, "DATEFROMPARTS(" + year + ", " + month + ", 1)");
                        sql = sql.replace(/FN_TINH_TIEN_CHISO\(([^,]+),\s*([^,]+),\s*\d+,\s*\d+\)/i, function(_, room, service) {
                            return "FN_TINH_TIEN_CHISO(" + room + ", " + service + ", " + month + ", " + year + ")";
                        });
                        sql = replaceValue(sql, /(CS\.Thang\s*=\s*)\d+/i, month);
                        sql = replaceValue(sql, /(CS\.Nam\s*=\s*)\d+/i, year);
                        break;
                    case "lap-hoa-don-thang":
                        sql = replaceValue(sql, /(DECLARE\s+@@MaHopDong\s+INT\s*=\s*)\d+/i, numberValue("param-ma-hop-dong", "0"));
                        sql = replaceValue(sql, /(@@MaNguoiLap\s*=\s*)\d+/i, String(currentUserId));
                        sql = replaceValue(sql, /(@@Thang\s*=\s*)\d+/i, numberValue("param-thang", ""));
                        sql = replaceValue(sql, /(@@Nam\s*=\s*)\d+/i, numberValue("param-nam", ""));
                        break;
                    case "ghi-nhan-thanh-toan":
                        sql = replaceValue(sql, /(DECLARE\s+@@MaHoaDon\s+INT\s*=\s*)\d+/i, numberValue("param-ma-hoa-don", "0"));
                        sql = replaceValue(sql, /(DECLARE\s+@@SoTienThanhToan\s+DECIMAL\(18,0\)\s*=\s*)\d+/i, numberValue("param-so-tien", "0"));
                        sql = replaceValue(sql, /(@@MaNguoiThu\s*=\s*)\d+/i, String(currentUserId));
                        sql = replaceValue(sql, /(@@NgayThu\s*=\s*)'[^']*'/i, sqlString($("#param-ngay-thu").val(), false));
                        sql = replaceValue(sql, /(@@HinhThuc\s*=\s*)'(?:''|[^'])*'/i, sqlString($("#param-hinh-thuc").val(), false));
                        break;
                    case "tinh-cong-no-hop-dong":
                        var contractId = numberValue("param-ma-hop-dong", "");
                        sql = replaceValue(sql, /(DECLARE\s+@@MaHopDong\s+INT\s*=\s*)\d+/i, contractId || "0");
                        break;
                    case "quet-hoa-don-qua-han":
                    case "quet-hop-dong-het-han":
                        var scanDate = $("#param-ngay-quet").val();
                        if (scanDate) {
                            sql = sql.replace(/CAST\(GETDATE\(\)\s+AS\s+DATE\)/gi, sqlString(scanDate, false));
                            sql = replaceValue(sql, /(<\s*)'\d{4}-\d{2}-\d{2}'/i, sqlString(scanDate, false));
                        }
                        break;
                }

                textarea.value = sql;
            }

            $(".sql-param").on("input change", updateSql);

            function syncContractDates() {
                var start = $("#param-ngay-bat-dau").val();
                var endInput = document.getElementById("param-ngay-ket-thuc");
                if (!endInput) return;
                endInput.min = start || "";
                if (start && endInput.value && endInput.value <= start) {
                    endInput.setCustomValidity("Ngày kết thúc phải lớn hơn ngày bắt đầu.");
                } else {
                    endInput.setCustomValidity("");
                }
            }

            function refreshPreviousReading() {
                if (scenarioId !== "ghi-chi-so") return;
                var roomId = $("#param-ma-phong").val();
                var serviceId = $("#param-ma-dich-vu").val();
                var period = ($("#param-ky").val() || "").split("-");
                if (!roomId || !serviceId || period.length !== 2) {
                    $("#param-chi-so-cu").val(0);
                    $("#param-chi-so-moi").attr("min", 0);
                    return;
                }

                $.getJSON("@Url.Action("PreviousReading", "SqlDemo")", {
                    roomId: roomId,
                    serviceId: serviceId,
                    month: Number(period[1]),
                    year: Number(period[0])
                }).done(function(result) {
                    var previous = Number(result.value || 0);
                    $("#param-chi-so-cu").val(previous);
                    $("#param-chi-so-moi").attr("min", previous);
                });
            }

            function refreshPaymentLimit() {
                if (scenarioId !== "ghi-nhan-thanh-toan") return;
                var selected = $("#param-ma-hoa-don option:selected");
                var debt = Number(selected.data("debt") || 0);
                var amountInput = $("#param-so-tien");
                if (debt > 0) {
                    amountInput.attr("max", debt);
                    $("#payment-debt-note").text("Số nợ còn lại: " + new Intl.NumberFormat("vi-VN").format(debt) + " đ.");
                } else {
                    amountInput.removeAttr("max");
                    $("#payment-debt-note").text("Chọn hóa đơn để xem số nợ còn lại.");
                }
            }

            $("#param-ngay-bat-dau, #param-ngay-ket-thuc").on("change", syncContractDates);
            $("#param-ma-phong, #param-ma-dich-vu, #param-ky").on("change", refreshPreviousReading);
            $("#param-ma-hoa-don").on("change", refreshPaymentLimit);

            syncContractDates();
            refreshPreviousReading();
            refreshPaymentLimit();
            updateSql();

            $("#btn-reset-sql").click(function() {
                if (textarea) {
                    $(".sql-param").each(function() {
                        this.value = "";
                    });
                    textarea.value = originalSql;
                }
            });

            setTimeout(function() {
                $("#sql-demo-success-message").fadeOut(300);
            }, 5000);

        });
    </script>
}

