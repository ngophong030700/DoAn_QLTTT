@model DichVu
@{
    ViewData["Title"] = "Chi tiết dịch vụ";
}

<div class="detail-panel">
    <dl class="row mb-0">
        <dt class="col-sm-3">Tên dịch vụ</dt>
        <dd class="col-sm-9">@Model.TenDichVu</dd>
        <dt class="col-sm-3">Đơn vị</dt>
        <dd class="col-sm-9">@Model.DonVi</dd>
        <dt class="col-sm-3">Đơn giá</dt>
        <dd class="col-sm-9">@FormatHelper.Money(Model.DonGia)</dd>
        <dt class="col-sm-3">Loại tính phí</dt>
        <dd class="col-sm-9">@Model.LoaiTinhPhi</dd>
    </dl>
    <div class="mt-4 d-flex gap-2">
        <a class="btn btn-primary" asp-action="Edit" asp-route-id="@Model.MaDichVu">Sửa</a>
        <a class="btn btn-outline-secondary" asp-action="Index">Quay lại</a>
    </div>
</div>
