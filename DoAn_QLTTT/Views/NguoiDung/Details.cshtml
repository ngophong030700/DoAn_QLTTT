@model NguoiDung
@{
    ViewData["Title"] = "Chi tiết người dùng";
}

<div class="detail-panel">
    <dl class="row mb-0">
        <dt class="col-sm-3">Tên đăng nhập</dt>
        <dd class="col-sm-9">@Model.TenDangNhap</dd>
        <dt class="col-sm-3">Họ tên</dt>
        <dd class="col-sm-9">@Model.HoTen</dd>
        <dt class="col-sm-3">Vai trò</dt>
        <dd class="col-sm-9"><span class="badge @BadgeHelper.VaiTroClass(Model.VaiTro)">@Model.VaiTro</span></dd>
        <dt class="col-sm-3">Hoạt động</dt>
        <dd class="col-sm-9">@(Model.DangHoatDong ? "Có" : "Không")</dd>
    </dl>
    <div class="mt-4 d-flex gap-2">
        <a class="btn btn-primary" asp-action="Edit" asp-route-id="@Model.MaNguoiDung">Sửa</a>
        <a class="btn btn-outline-secondary" asp-action="Index">Quay lại</a>
    </div>
</div>
