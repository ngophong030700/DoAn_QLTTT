@model SqlDemoPageViewModel
@{
    ViewData["Title"] = "Demo SQL";
    var scenario = Model.SelectedScenario;
}

<div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-3">
    <div>
        <h1 class="h4 fw-800 mb-1">Demo SQL</h1>
        <div class="text-muted fw-600">Procedure, trigger, function và cursor</div>
    </div>
    <span class="badge @(Model.IsMock ? "bg-warning text-dark" : "bg-primary")">
        Nguồn dữ liệu: @(Model.IsMock ? "Mock Data" : "SQL Server")
    </span>
</div>

@if (Model.IsMock)
{
    <div class="alert alert-warning" role="alert">
        <i class="bi bi-exclamation-triangle-fill me-2"></i>
        Chế độ Mock Data chỉ dùng để dựng giao diện. Khi nộp/demo chính thức cần chuyển DataProvider sang SqlServer và kết nối SQL Server thật.
    </div>
}

<div class="row g-4">
    <div class="col-xl-3">
        <div class="table-card">
            <div class="p-3 border-bottom bg-white">
                <h2 class="h6 mb-0 fw-800 text-uppercase">Kịch bản demo</h2>
            </div>
            <div class="list-group list-group-flush">
                @foreach (var item in Model.Scenarios)
                {
                    <a class="list-group-item list-group-item-action @(scenario?.Id == item.Id ? "active" : "")"
                       asp-controller="SqlDemo"
                       asp-action="Index"
                       asp-route-id="@item.Id">
                        <div class="fw-700">@item.Title</div>
                        <small>@item.Type</small>
                    </a>
                }
            </div>
        </div>
    </div>

    <div class="col-xl-9">
        @if (scenario is not null)
        {
            <section class="table-card mb-4">
                <div class="p-3 border-bottom bg-white d-flex flex-wrap justify-content-between align-items-center gap-2">
                    <div>
                        <h2 class="h6 mb-1 fw-800 text-uppercase">Bài toán</h2>
                        <div class="fw-700">@scenario.Title</div>
                    </div>
                    <div>
                        <span class="badge bg-light text-dark">@scenario.Type</span>
                        @if (Model.IsMock)
                        {
                            <span class="badge bg-warning text-dark ms-1">Mock Data</span>
                        }
                    </div>
                </div>
                <div class="p-3">
                    <p class="mb-0 fw-600">@scenario.Problem</p>
                    @if (!string.IsNullOrWhiteSpace(scenario.Note))
                    {
                        <div class="text-muted mt-2">@scenario.Note</div>
                    }
                </div>
            </section>

            <section class="table-card mb-4">
                <form asp-controller="SqlDemo" asp-action="Execute" method="post">
                    <div class="p-3 border-bottom bg-white d-flex flex-wrap justify-content-between align-items-center gap-2">
                        <h2 class="h6 mb-0 fw-800 text-uppercase">Câu truy vấn</h2>
                        <div>
                            <input type="hidden" name="id" value="@scenario.Id" />
                            <button class="btn btn-primary" type="submit">
                                <i class="bi bi-play-fill me-1"></i>Thực thi
                            </button>
                        </div>
                    </div>
                    <div class="p-3">
                        <div class="row g-3 align-items-stretch">
                            <div class="col-lg-6 d-flex">
                                <div class="sql-code-frame">
                                    <label class="sql-code-title" for="sqlScript">Câu lệnh demo</label>
                                    <textarea class="sql-code-block sql-code-editor" id="sqlScript" name="sqlScript" spellcheck="false">@scenario.SqlScript</textarea>
                                </div>
                            </div>
                            <div class="col-lg-6 d-flex">
                                <div class="sql-code-frame">
                                    <div class="sql-code-title">Nội dung @scenario.Type</div>
                                    <pre class="sql-code-block"><code>@scenario.ObjectScript</code></pre>
                                </div>
                            </div>
                        </div>
                    </div>
                </form>
            </section>

            <section class="table-card mb-4">
                <div class="p-3 border-bottom bg-white">
                    <h2 class="h6 mb-0 fw-800 text-uppercase">Dữ liệu liên quan</h2>
                </div>
                <div class="p-3">
                    @await Html.PartialAsync("_SqlDemoTables", scenario.BeforeTables)
                </div>
            </section>

            <section class="table-card mb-4">
                <div class="p-3 border-bottom bg-white">
                    <h2 class="h6 mb-0 fw-800 text-uppercase">Kết quả sau khi chạy</h2>
                </div>
                <div class="p-3">
                    @if (!string.IsNullOrWhiteSpace(scenario.ErrorMessage))
                    {
                        <div class="alert alert-danger mb-0">@scenario.ErrorMessage</div>
                    }
                    else if (!scenario.HasExecuted)
                    {
                        <div class="alert alert-info mb-0">Bấm Thực thi để xem dữ liệu sau khi chạy.</div>
                    }
                    else
                    {
                        @if (!string.IsNullOrWhiteSpace(scenario.OutputTitle) || !string.IsNullOrWhiteSpace(scenario.OutputMessage))
                        {
                            <div class="alert alert-success">
                                @if (!string.IsNullOrWhiteSpace(scenario.OutputTitle))
                                {
                                    <div class="fw-800">@scenario.OutputTitle</div>
                                }
                                @scenario.OutputMessage
                            </div>
                        }
                        @await Html.PartialAsync("_SqlDemoTables", scenario.AfterTables)
                    }
                </div>
            </section>
        }
    </div>
</div>
