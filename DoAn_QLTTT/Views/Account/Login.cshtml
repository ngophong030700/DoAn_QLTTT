@model LoginViewModel
@{
    Layout = null;
    ViewData["Title"] = "Đăng nhập";
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Đăng nhập - UIT Hostels Management</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="login-page">
    <main class="login-shell">
        <section class="login-card shadow-lg">
            <div class="login-brand">
                <img src="https://upload.wikimedia.org/wikipedia/commons/0/00/Logo_UIT_updated.svg" alt="UIT Logo" />
                <div>
                    <h1>Đăng nhập hệ thống</h1>
                    <p>Quản lý thuê phòng trọ</p>
                </div>
            </div>

            <form asp-action="Login" method="post" class="mt-4">
                <input asp-for="ReturnUrl" type="hidden" />
                <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small"></div>

                <div class="mb-3">
                    <label asp-for="TenDangNhap" class="form-label fw-700"></label>
                    <div class="input-group">
                        <span class="input-group-text"><i class="bi bi-person"></i></span>
                        <input asp-for="TenDangNhap" class="form-control" autofocus autocomplete="username" />
                    </div>
                    <span asp-validation-for="TenDangNhap" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="MatKhau" class="form-label fw-700"></label>
                    <div class="input-group">
                        <span class="input-group-text"><i class="bi bi-lock"></i></span>
                        <input asp-for="MatKhau" class="form-control" autocomplete="current-password" />
                    </div>
                    <span asp-validation-for="MatKhau" class="text-danger small"></span>
                </div>

                <div class="form-check mb-4">
                    <input asp-for="GhiNhoDangNhap" class="form-check-input" />
                    <label asp-for="GhiNhoDangNhap" class="form-check-label">Ghi nhớ đăng nhập</label>
                </div>

                <button type="submit" class="btn btn-primary w-100 py-2 fw-700">
                    <i class="bi bi-box-arrow-in-right me-1"></i> Đăng nhập
                </button>
            </form>
        </section>
    </main>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
</body>
</html>
